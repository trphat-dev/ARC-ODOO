<odoo>
    <data noupdate="1">

        <!-- Sequence for training references -->
        <record id="seq_ai_model_training" model="ir.sequence">
            <field name="name">AI Model Training</field>
            <field name="code">ai.model.training</field>
            <field name="prefix">TRAIN-</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>

        <!-- Sequence for prediction references -->
        <record id="seq_ai_prediction" model="ir.sequence">
            <field name="name">AI Prediction</field>
            <field name="code">ai.prediction</field>
            <field name="prefix">PRED-</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>

        <!-- Sequence for chatbot conversation references -->
        <record id="seq_ai_chatbot_conversation" model="ir.sequence">
            <field name="name">AI Chatbot Conversation</field>
            <field name="code">ai.chatbot.conversation</field>
            <field name="prefix">CHAT-</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>

    </data>
</odoo>

