<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ai_trading_assistant.WebsiteChatbot">
        <div class="o_ai_chatbot_container" t-att-class="state.isOpen ? 'open' : ''">
            <!-- Chat Trigger Button -->
            <div class="o_ai_chatbot_trigger" t-on-click="toggleChat">
                <i t-if="state.isOpen" class="fa fa-times"/>
                <img t-else="" src="/ai_trading_assistant/static/description/icon.png" class="o_chat_icon_img" alt="AI"/>
                <span class="o_ai_notification_badge" t-if="state.unreadCount > 0" t-esc="state.unreadCount"/>
            </div>

            <!-- Signal Popup Modal -->
            <div class="o_signal_popup" t-if="state.activeSignal">
                <div class="o_signal_popup_overlay" t-on-click="dismissSignal"/>
                <div class="o_signal_popup_content" t-att-class="'o_signal_' + state.activeSignal.signal_type">
                    <div class="o_signal_header">
                        <i t-if="state.activeSignal.signal_type === 'buy'" class="fa fa-arrow-up"/>
                        <i t-if="state.activeSignal.signal_type === 'sell'" class="fa fa-arrow-down"/>
                        <span class="o_signal_type" t-esc="state.activeSignal.signal_type === 'buy' ? 'MUA' : 'BÁN'"/>
                    </div>
                    <div class="o_signal_body">
                        <div class="o_signal_symbol" t-esc="state.activeSignal.symbol"/>
                        <div class="o_signal_price">
                            <span class="label">Giá hiện tại:</span>
                            <span class="value" t-esc="state.activeSignal.current_price?.toLocaleString() + ' đ'"/>
                        </div>
                        <div class="o_signal_confidence">
                            <span class="label">Độ tin cậy:</span>
                            <span class="value" t-esc="(state.activeSignal.confidence || 0).toFixed(1) + '%'"/>
                        </div>
                        <div class="o_signal_quantity">
                            <label>Số lượng:</label>
                            <input type="number" class="form-control" 
                                   t-att-value="state.tradeQuantity"
                                   t-on-change="onQuantityChange"
                                   min="10" step="10"/>
                        </div>
                    </div>
                    <div class="o_signal_actions">
                        <button class="btn btn-lg o_btn_confirm" t-on-click="confirmTrade">
                            <i class="fa fa-check me-2"/>Đặt lệnh ngay
                        </button>
                        <button class="btn btn-lg o_btn_dismiss" t-on-click="dismissSignal">
                            <i class="fa fa-times me-2"/>Bỏ qua
                        </button>
                    </div>
                </div>
            </div>

            <!-- Chat Window -->
            <div class="o_ai_chatbot_window" t-if="state.isOpen">
                <!-- Header -->
                <div class="o_ai_chatbot_header">
                    <div class="d-flex align-items-center">
                        <div class="o_ai_avatar me-2">
                            <img src="/ai_trading_assistant/static/description/icon.png" alt="Avatar"/>
                        </div>
                        <div>
                            <h5 class="mb-0">AI Consultant</h5>
                            <small>Trading Assistant</small>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <!-- Watchlist Toggle -->
                        <div class="o_watchlist_toggle" t-on-click="toggleWatchlistPanel" title="Quản lý Watchlist">
                            <i class="fa fa-star"/>
                            <span class="o_watchlist_count" t-if="state.watchlist.length > 0" t-esc="state.watchlist.length"/>
                        </div>
                        <div class="o_ai_chatbot_close" t-on-click="toggleChat">
                            <i class="fa fa-times"/>
                        </div>
                    </div>
                </div>

                <!-- Watchlist Panel -->
                <div class="o_watchlist_panel" t-if="state.showWatchlistPanel">
                    <div class="o_watchlist_header">
                        <h6><i class="fa fa-star me-2"/>Danh sách theo dõi</h6>
                        <i class="fa fa-times o_close_panel" t-on-click="toggleWatchlistPanel"/>
                    </div>
                    
                    <!-- Current Watchlist -->
                    <div class="o_current_watchlist" t-if="state.watchlist.length > 0">
                        <t t-foreach="state.watchlist" t-as="item" t-key="item.id">
                            <div class="o_watchlist_item">
                                <span class="o_symbol" t-esc="item.symbol"/>
                                <span class="o_market" t-esc="item.market"/>
                                <button class="btn btn-sm o_remove_btn" t-on-click="() => this.removeFromWatchlist(item.security_id)">
                                    <i class="fa fa-times"/>
                                </button>
                            </div>
                        </t>
                    </div>
                    <div class="o_empty_watchlist" t-else="">
                        <i class="fa fa-info-circle me-2"/>Chưa có mã nào
                    </div>

                    <!-- Search Securities -->
                    <div class="o_search_securities">
                        <input type="text" 
                               class="form-control" 
                               placeholder="Tìm mã cổ phiếu..."
                               t-on-input="onSearchInput"/>
                        <div class="o_search_results" t-if="state.searchResults.length > 0">
                            <t t-foreach="state.searchResults" t-as="sec" t-key="sec.id">
                                <div class="o_search_item" t-att-class="isInWatchlist(sec.id) ? 'in_watchlist' : ''">
                                    <div class="o_sec_info">
                                        <span class="o_symbol" t-esc="sec.symbol"/>
                                        <span class="o_name" t-esc="sec.name"/>
                                    </div>
                                    <button class="btn btn-sm" 
                                            t-on-click="() => this.addToWatchlist(sec.id)"
                                            t-att-disabled="isInWatchlist(sec.id)">
                                        <i t-att-class="isInWatchlist(sec.id) ? 'fa fa-check' : 'fa fa-plus'"/>
                                    </button>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- Messages Area -->
                <div class="o_ai_chatbot_body" t-ref="messages" t-att-class="state.showWatchlistPanel ? 'd-none' : ''">
                    <t t-if="!state.messages.length">
                        <div class="text-center p-4 text-muted">
                            <i class="fa fa-chart-line fa-3x mb-3"/>
                            <p>Xin chào! Tôi là AI Trading Consultant.</p>
                            <p class="mb-3">Hỏi tôi về chiến lược, hiệu suất hoặc dự đoán thị trường.</p>
                        </div>
                        
                        <!-- Quick Suggestions -->
                        <div class="o_quick_suggestions" t-if="state.showSuggestions">
                            <p class="text-muted small text-center mb-2">💡 Gợi ý nhanh:</p>
                            <div class="d-flex flex-wrap justify-content-center gap-2 px-3">
                                <t t-foreach="quickSuggestions" t-as="suggestion" t-key="suggestion">
                                    <button class="btn btn-outline-primary btn-sm o_quick_btn" 
                                            t-on-click="() => this.sendQuickMessage(suggestion)">
                                        <t t-esc="suggestion"/>
                                    </button>
                                </t>
                            </div>
                        </div>
                    </t>
                    
                    <t t-foreach="state.messages" t-as="msg" t-key="msg.id">
                        <div class="o_ai_message" t-att-class="msg.role === 'user' ? 'user' : 'bot'">
                            <div class="o_message_content">
                                <t t-esc="msg.content"/>
                                
                                <!-- Reasoning Details (Collapsible) -->
                                <t t-if="msg.reasoning_details">
                                    <div class="o_ai_reasoning mt-2">
                                        <div class="o_reasoning_header" t-on-click="() => this.toggleReasoning(msg.id)">
                                            <i class="fa fa-brain me-1"/> Agent Reasoning
                                            <i t-att-class="state.reasoningOpen[msg.id] ? 'fa fa-caret-up ms-auto' : 'fa fa-caret-down ms-auto'"/>
                                        </div>
                                        <div class="o_reasoning_body" t-if="state.reasoningOpen[msg.id]">
                                            <pre t-esc="msg.reasoning_details"/>
                                        </div>
                                    </div>
                                </t>
                            </div>
                            <small class="o_message_time" t-esc="msg.time"/>
                        </div>
                    </t>
                    
                    <!-- Typing Indicator -->
                    <div class="o_ai_message bot" t-if="state.isTyping">
                        <div class="o_typing_indicator">
                            <span>.</span><span>.</span><span>.</span>
                        </div>
                    </div>
                </div>

                <!-- Input Area -->
                <div class="o_ai_chatbot_footer" t-att-class="state.showWatchlistPanel ? 'd-none' : ''">
                    <input type="text" 
                           class="form-control" 
                           placeholder="Hỏi về danh mục của bạn..." 
                           t-model="state.input"
                           t-on-keydown="_onKeydown"
                           t-att-disabled="state.isTyping"/>
                    <button class="btn btn-primary btn-sm ms-2" t-on-click="_sendMessage" t-att-disabled="!state.input or state.isTyping">
                        <i class="fa fa-paper-plane"/>
                    </button>
                </div>
            </div>
        </div>
    </t>
</templates>
