<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_chatbot_global_config_list" model="ir.ui.view">
        <field name="name">ai.chatbot.global.config.list</field>
        <field name="model">ai.chatbot.global.config</field>
        <field name="arch" type="xml">
            <list string="Chatbot Configurations">
                <field name="name"/>
                <field name="provider"/>
                <field name="model_name"/>
                <field name="is_default"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_ai_chatbot_global_config_form" model="ir.ui.view">
        <field name="name">ai.chatbot.global.config.form</field>
        <field name="model">ai.chatbot.global.config</field>
        <field name="arch" type="xml">
            <form string="Chatbot Configuration">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="provider" readonly="1"/>
                            <field name="model_name"/>
                        </group>
                        <group>
                            <field name="api_key" password="True"/>
                            <field name="is_default"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Optional notes..."/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <p><strong>Usage:</strong> This API key and default model are shared by all AI Trading Assistant features (Chatbot, Investor Copilot, etc.).</p>
                        <p>OpenRouter portal: <a href="https://openrouter.ai/keys" target="_blank">https://openrouter.ai/keys</a></p>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_chatbot_global_config" model="ir.actions.act_window">
        <field name="name">Chatbot Settings</field>
        <field name="res_model">ai.chatbot.global.config</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'default_is_default': True}</field>
    </record>
</odoo>

