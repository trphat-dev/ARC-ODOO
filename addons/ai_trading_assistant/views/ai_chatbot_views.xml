<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_chatbot_conversation_list" model="ir.ui.view">
        <field name="name">ai.chatbot.conversation.list</field>
        <field name="model">ai.chatbot.conversation</field>
        <field name="arch" type="xml">
            <list string="Chatbot Conversations">
                <field name="name"/>
                <field name="message_count"/>
                <field name="active"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="view_ai_chatbot_conversation_form" model="ir.ui.view">
        <field name="name">ai.chatbot.conversation.form</field>
        <field name="model">ai.chatbot.conversation</field>
        <field name="arch" type="xml">
            <form string="Chatbot Conversation">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="user_id"/>
                        <field name="config_id"/>
                        <field name="active"/>
                    </group>
                    <field name="messages" readonly="1">
                        <list>
                            <field name="role" widget="badge" decoration-info="role == 'user'" decoration-success="role == 'assistant'"/>
                            <field name="content" widget="text"/>
                            <field name="is_error"/>
                            <field name="create_date"/>
                        </list>
                    </field>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_chatbot_conversation" model="ir.actions.act_window">
        <field name="name">AI Chatbot</field>
        <field name="res_model">ai.chatbot.conversation</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('user_id', '=', uid), ('active', '=', True)]</field>
        <field name="context">{'default_user_id': uid}</field>
    </record>
</odoo>

