<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_model_training_list" model="ir.ui.view">
        <field name="name">ai.model.training.list</field>
        <field name="model">ai.model.training</field>
        <field name="arch" type="xml">
            <list string="Model Training">
                <field name="name"/>
                <field name="strategy_id"/>
                <field name="finrl_algorithm" string="Algorithm"/>
                <field name="state" widget="badge" decoration-success="state == 'completed'" decoration-danger="state == 'failed'" decoration-warning="state in ('downloading', 'training')"/>
                <field name="sharpe_ratio" string="Sharpe"/>
                <field name="cumulative_reward" string="Return"/>
                <field name="training_duration"/>
            </list>
        </field>
    </record>

    <record id="view_ai_model_training_kanban" model="ir.ui.view">
        <field name="name">ai.model.training.kanban</field>
        <field name="model">ai.model.training</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <field name="name"/>
                <field name="strategy_id"/>
                <field name="state"/>
                <field name="progress_percent"/>
                <field name="training_duration"/>
                <field name="sharpe_ratio"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record_top mb-2">
                            <div class="o_kanban_record_headings">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <span class="text-muted"><field name="strategy_id"/></span>
                            </div>
                            <div class="o_dropdown_kanban dropdown">
                                <a role="button" class="dropdown-toggle o-no-caret btn" data-bs-toggle="dropdown" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                    <span class="fa fa-ellipsis-v"/>
                                </a>
                                <div class="dropdown-menu" role="menu">
                                    <a role="menuitem" type="edit" class="dropdown-item">Edit</a>
                                    <a role="menuitem" type="delete" class="dropdown-item">Delete</a>
                                </div>
                            </div>
                        </div>
                        <div class="o_kanban_record_body">
                            <div class="d-flex justify-content-between mb-2">
                                <span t-if="record.sharpe_ratio.value > 0" class="badge text-bg-success">
                                    Sharpe: <field name="sharpe_ratio"/>
                                </span>
                                <span t-else="" class="badge text-bg-light">
                                    Duration: <field name="training_duration" widget="float_time"/>
                                </span>
                            </div>
                            <div t-if="record.state.raw_value == 'training' or record.state.raw_value == 'downloading'" class="mt-2">
                                <field name="progress_percent" widget="progressbar"/>
                            </div>
                        </div>
                        <div class="o_kanban_record_bottom mt-2">
                            <div class="oe_kanban_bottom_left">
                                <field name="state" widget="label_selection" options="{'classes': {'completed': 'success', 'failed': 'danger', 'training': 'warning', 'downloading': 'info', 'pending': 'secondary'}}"/>
                            </div>
                            <div class="oe_kanban_bottom_right">
                                <field name="create_date" widget="date"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_ai_model_training_form" model="ir.ui.view">
        <field name="name">ai.model.training.form</field>
        <field name="model">ai.model.training</field>
        <field name="arch" type="xml">
            <form string="Model Training">
                <header>
                    <button name="action_start_finrl_training" string="Start FinRL Training" type="object" class="btn-primary" invisible="state != 'pending'"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,downloading,training,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <widget name="web_ribbon" title="Completed" bg_color="bg-success" invisible="state != 'completed'"/>
                    <widget name="web_ribbon" title="Failed" bg_color="bg-danger" invisible="state != 'failed'"/>
                    <widget name="web_ribbon" title="Training" bg_color="bg-warning" invisible="state != 'training'"/>
                    <group>
                        <group name="strategy_info" string="Strategy &amp; Config">
                            <field name="strategy_id" options="{'no_create': True}"/>
                            <field name="config_id" readonly="1"/>
                            <field name="model_type" readonly="1"/>
                            <field name="finrl_algorithm" readonly="1" string="Algorithm"/>
                        </group>
                        <group name="dates" string="Timeframe">
                            <field name="from_date"/>
                            <field name="to_date"/>
                            <label for="training_duration" string="Duration"/>
                            <div class="o_row">
                                <field name="training_duration" widget="float_time"/>
                                <span>(seconds)</span>
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Progress &amp; Metrics" name="metrics">
                            <group>
                                <group string="Training Progress">
                                    <field name="progress_percent" widget="progressbar"/>
                                </group>
                                <group string="Key Metrics">
                                    <field name="sharpe_ratio" widget="float" digits="[16, 4]"/>
                                    <field name="cumulative_reward" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="max_drawdown" widget="percentage"/>
                                </group>
                            </group>
                            <group>
                                <group string="Trading Stats">
                                    <field name="total_trades"/>
                                    <field name="model_accuracy" string="Win Rate (%)" widget="percentage"/>
                                    <field name="model_precision" string="Profit Factor" widget="float"/>
                                </group>
                                <group string="Algorithm Info">
                                    <field name="training_timesteps" readonly="1"/>
                                    <field name="training_start_time" readonly="1"/>
                                    <field name="training_end_time" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Model &amp; System Info" name="model_info">
                            <group>
                                <group string="Model Storage">
                                    <field name="finrl_model_path" readonly="1" string="Primary Model Path"/>
                                    <field name="model_path" readonly="1" string="Export Path"/>
                                </group>
                                <group string="Legacy / Internal Info" invisible="not freqai_identifier">
                                    <field name="freqai_identifier" readonly="1"/>
                                    <field name="freqai_model_path" readonly="1"/>
                                    <field name="freqai_model_type" readonly="1"/>
                                </group>
                            </group>
                            <div class="alert alert-secondary" role="alert">
                                <p><i class="fa fa-info-circle"/> <strong>System Note:</strong> The Model Path points to the exact weights used for prediction. <strong>Sharpe Ratio</strong> higher than 1.0 is generally considered good for these strategies.</p>
                            </div>
                        </page>
                        <page string="Training Log">
                            <field name="training_log" readonly="1" nolabel="1"/>
                        </page>
                        <page string="Error Log">
                            <field name="error_message" readonly="1" invisible="not error_message" nolabel="1"/>
                        </page>
                        <page string="Raw Metrics">
                            <field name="raw_metrics" readonly="1" widget="text" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_ai_model_training" model="ir.actions.act_window">
        <field name="name">Model Training</field>
        <field name="res_model">ai.model.training</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('strategy_id.user_id', '=', uid)]</field>
    </record>
</odoo>
