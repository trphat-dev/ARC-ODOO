<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_prediction_list" model="ir.ui.view">
        <field name="name">ai.prediction.list</field>
        <field name="model">ai.prediction</field>
        <field name="arch" type="xml">
            <list string="AI Predictions">
                <field name="name"/>
                <field name="strategy_id"/>
                <field name="security_id"/>
                <field name="symbol"/>
                <field name="prediction_date"/>
                <field name="final_signal" widget="badge" decoration-success="final_signal == 'buy'" decoration-danger="final_signal == 'sell'"/>
                <field name="lean_signal_state" widget="badge"/>
                <field name="prediction_confidence"/>
            </list>
        </field>
    </record>

    <record id="view_ai_prediction_kanban" model="ir.ui.view">
        <field name="name">ai.prediction.kanban</field>
        <field name="model">ai.prediction</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="strategy_id" default_order="prediction_date desc">
                <field name="name"/>
                <field name="symbol"/>
                <field name="final_signal"/>
                <field name="prediction_confidence"/>
                <field name="prediction_date"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record_top mb-2">
                             <div class="o_kanban_record_headings">
                                <strong class="o_kanban_record_title">
                                    <field name="symbol"/>
                                    <span class="ms-2 text-muted"><field name="name"/></span>
                                </strong>
                            </div>
                            <div class="o_dropdown_kanban dropdown">
                                <a role="button" class="dropdown-toggle o-no-caret btn" data-bs-toggle="dropdown" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                    <span class="fa fa-ellipsis-v"/>
                                </a>
                                <div class="dropdown-menu" role="menu">
                                    <a role="menuitem" type="edit" class="dropdown-item">Edit</a>
                                    <a role="menuitem" type="delete" class="dropdown-item">Delete</a>
                                </div>
                            </div>
                        </div>
                         <div class="o_kanban_record_body">
                            <div class="row mb-2">
                                <div class="col-6">
                                    <field name="final_signal" widget="badge" decoration-success="final_signal == 'buy'" decoration-danger="final_signal == 'sell'" decoration-muted="final_signal == 'hold'"/>
                                </div>
                                <div class="col-6 text-end">
                                    <field name="prediction_confidence" widget="percentpie" nolabel="1"/>
                                </div>
                            </div>
                        </div>
                        <div class="o_kanban_record_bottom">
                            <div class="oe_kanban_bottom_left">
                                <field name="prediction_date" widget="date"/>
                            </div>
                            <div class="oe_kanban_bottom_right">
                                <field name="strategy_id"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_ai_prediction_graph" model="ir.ui.view">
        <field name="name">ai.prediction.graph</field>
        <field name="model">ai.prediction</field>
        <field name="arch" type="xml">
            <graph string="Prediction Analysis" type="bar">
                <field name="prediction_date" interval="day"/>
                <field name="final_signal"/>
            </graph>
        </field>
    </record>

    <record id="view_ai_prediction_form" model="ir.ui.view">
        <field name="name">ai.prediction.form</field>
        <field name="model">ai.prediction</field>
        <field name="arch" type="xml">
            <form string="AI Prediction">
                <header>
                    <button name="action_view_chart"
                            string="View Chart"
                            type="object"
                            class="btn-primary"
                            icon="fa-bar-chart"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Prediction Reference"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_chart"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-bar-chart"
                                string="View Chart"/>
                    </div>
                    <widget name="web_ribbon" title="Buy" bg_color="bg-success" invisible="final_signal != 'buy'"/>
                    <widget name="web_ribbon" title="Sell" bg_color="bg-danger" invisible="final_signal != 'sell'"/>
                    <group>
                        <group name="prediction_info" string="Prediction Details">
                            <field name="strategy_id" options="{'no_create': True}"/>
                            <field name="prediction_date"/>
                            <field name="prediction_confidence" widget="progressbar"/>
                        </group>
                        <group name="security_info" string="Security &amp; Signal">
                            <field name="security_id" options="{'no_create': True, 'no_create_edit': True}" domain="[('market', '=', market)]"/>
                            <field name="symbol" font_weight="bold"/>
                            <field name="market" readonly="1"/>
                            <field name="final_signal" widget="badge" decoration-success="final_signal == 'buy'" decoration-danger="final_signal == 'sell'" decoration-info="final_signal == 'hold'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Technical Indicators" name="indicators">
                            <group>
                                <group string="Price &amp; Momentum">
                                    <field name="current_price" widget="monetary"/>
                                    <field name="rsi_value" widget="gauge" options="{'max_value': 100}"/>
                                    <field name="volume_ratio" string="Vol/Avg MA"/>
                                    <field name="volume_above_threshold" widget="boolean_toggle"/>
                                </group>
                                <group string="Trend (SMA 50/200)">
                                    <field name="sma_50_value" widget="monetary"/>
                                    <field name="sma_200_value" widget="monetary"/>
                                    <field name="ma_signal_type" widget="badge" decoration-success="ma_signal_type == 'golden_cross'" decoration-danger="ma_signal_type == 'death_cross'"/>
                                    <field name="ma_cross_above" invisible="1"/>
                                    <field name="ma_cross_below" invisible="1"/>
                                </group>
                            </group>
                            <group>
                                <group string="MACD Confirmation">
                                    <field name="macd_value"/>
                                    <field name="macd_signal_value"/>
                                    <field name="macd_hist_value"/>
                                    <div class="alert alert-info" role="alert" invisible="not macd_bullish">
                                        <i class="fa fa-arrow-up"/> <strong>MACD Bullish:</strong> Confirmation signal detected.
                                    </div>
                                    <div class="alert alert-danger" role="alert" invisible="not macd_bearish">
                                        <i class="fa fa-arrow-down"/> <strong>MACD Bearish:</strong> Downward trend suspected.
                                    </div>
                                    <field name="macd_bullish" invisible="1"/>
                                    <field name="macd_bearish" invisible="1"/>
                                </group>
                                <group string="Lean/Smart Indicators">
                                    <field name="lean_signal_state" widget="badge"/>
                                    <field name="trend_ema_slope"/>
                                    <field name="momentum_rsi"/>
                                    <field name="volatility_atr_pct" widget="percentage"/>
                                    <field name="volume_anomaly" widget="boolean_toggle"/>
                                </group>
                            </group>
                            <separator string="Logic Verification"/>
                            <group>
                                <group string="Module Signals">
                                    <field name="buy_signal"/>
                                    <field name="sell_signal"/>
                                    <field name="hold_signal"/>
                                </group>
                                <group string="Strategy Signals">
                                    <field name="strategy_buy_signal"/>
                                    <field name="strategy_sell_signal"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_ai_prediction" model="ir.actions.act_window">
        <field name="name">AI Predictions</field>
        <field name="res_model">ai.prediction</field>
        <field name="view_mode">kanban,list,form,graph</field>
        <field name="domain">[('strategy_id.user_id', '=', uid)]</field>
    </record>
</odoo>

