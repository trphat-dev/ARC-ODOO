<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_trading_config_list" model="ir.ui.view">
        <field name="name">ai.trading.config.list</field>
        <field name="model">ai.trading.config</field>
        <field name="arch" type="xml">
            <list string="AI Trading Configuration">
                <field name="name"/>
                <field name="user_id"/>
                <field name="ssi_config_id"/>
                <field name="drl_algorithm" string="DRL Algorithm"/>
                <field name="trading_mode"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_ai_trading_config_form" model="ir.ui.view">
        <field name="name">ai.trading.config.form</field>
        <field name="model">ai.trading.config</field>
        <field name="arch" type="xml">
            <form string="AI Trading Configuration">
                <header>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_strategies" type="object" class="oe_stat_button" icon="fa-list-alt">
                            <field name="strategy_count" widget="statinfo" string="Strategies"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Active" bg_color="bg-success" invisible="not active"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="user_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="trading_mode"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="SSI API Configuration">
                            <group>
                                <field name="ssi_config_id"/>
                            </group>
                        </page>
                        <page string="FinRL Settings">
                            <group>
                                <group string="DRL Algorithm">
                                    <field name="drl_algorithm"/>
                                    <field name="action_space_type"/>
                                </group>
                                <group string="Training Parameters">
                                    <field name="training_timesteps"/>
                                    <field name="learning_rate"/>
                                    <field name="finrl_gamma" string="Gamma"/>
                                </group>
                            </group>
                            <group>
                                <group string="Model Storage">
                                    <field name="finrl_model_dir"/>
                                    <field name="finrl_tensorboard_log"/>
                                </group>
                                <group string="Advanced">
                                    <field name="finrl_batch_size"/>
                                    <field name="finrl_n_steps"/>
                                </group>
                            </group>
                            <group string="Optuna Hyperparameter Tuning">
                                <group>
                                    <field name="enable_optuna"/>
                                </group>
                                <group invisible="not enable_optuna">
                                    <field name="optuna_trials"/>
                                    <field name="optuna_timesteps"/>
                                </group>
                            </group>
                            <div class="alert alert-info" role="alert">
                                <p><strong>FinRL Deep Reinforcement Learning:</strong></p>
                                <ul>
                                    <li><strong>Algorithms:</strong> PPO, A2C, SAC, TD3, DDPG</li>
                                    <li><strong>Ensemble:</strong> Combines multiple models (Voting) for robust predictions</li>
                                    <li><strong>Action Space:</strong> Discrete (Buy/Hold/Sell) or Continuous (Position Sizing)</li>
                                    <li><strong>Training Timesteps:</strong> Total environment steps for training (default: 50,000)</li>
                                    <li><strong>Learning Rate:</strong> Speed of agent learning (default: 0.0003)</li>
                                </ul>
                            </div>
                        </page>


                        <page string="Data Update">
                            <group>
                                <group string="Data Synchronization">
                                    <field name="auto_update_data"/>
                                </group>
                                <group string="Model Retraining">
                                    <field name="auto_retrain"/>
                                    <field name="retrain_interval_days"/>
                                </group>
                            </group>
                            <group string="Prediction Generation">
                                <group>
                                    <field name="auto_generate_predictions" readonly="1" help="Enable automatic continuous prediction generation for all active strategies"/>
                                    <field name="prediction_interval_minutes" help="How often the cron job will attempt to generate predictions"/>
                                    <field name="prediction_min_interval_minutes" help="Minimum time between predictions for the same symbol to avoid duplicates"/>
                                </group>
                                <group>
                                    <button name="action_start_auto_prediction" string="Start Auto-Prediction Loop" type="object" class="btn-primary" icon="fa-play" invisible="auto_generate_predictions"/>
                                    <button name="action_stop_auto_prediction" string="Stop Auto-Prediction Loop" type="object" class="btn-secondary" icon="fa-stop" invisible="not auto_generate_predictions"/>
                                </group>
                            </group>
                        </page>
                        <page string="Chatbot">
                            <group>
                                <field name="enable_chatbot"/>
                            </group>
                            <div class="alert alert-info" role="alert">
                                <p><strong>Global Settings:</strong> API keys and default models are now managed centrally under <em>AI Trading &gt; Chatbot Settings</em>. This page only toggles whether this trading config uses the chatbot.</p>
                            </div>
                        </page>
                        <page string="Notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_trading_config" model="ir.actions.act_window">
        <field name="name">AI Trading Configuration</field>
        <field name="res_model">ai.trading.config</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('user_id', '=', uid)]</field>
        <field name="context">{'default_user_id': uid, 'search_default_active': 1}</field>
    </record>
</odoo>
