<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_backtest_wizard_form" model="ir.ui.view">
        <field name="name">backtest.wizard.form</field>
        <field name="model">backtest.wizard</field>
        <field name="arch" type="xml">
            <form string="Run Backtest">
                <sheet>
                    <div class="alert alert-info" role="alert" invisible="backtest_mode != 'monte_carlo'">
                        <i class="fa fa-info-circle"/> <strong>Monte Carlo Simulation:</strong> This process runs 1000+ simulations to verify strategy robustness. It may take a few minutes.
                    </div>
                    <div class="alert alert-warning" role="alert" invisible="backtest_mode != 'walk_forward'">
                        <i class="fa fa-exclamation-triangle"/> <strong>Walk-Forward Analysis:</strong> This splits data into multiple training/testing windows to check for overfitting. Computationally intensive.
                    </div>
                    <group>
                        <group string="Period &amp; Capital">
                            <field name="strategy_id" invisible="1"/>
                            <field name="initial_capital" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="from_date"/>
                            <field name="to_date"/>
                        </group>
                        <group string="Configuration">
                            <field name="backtest_mode" widget="radio"/>
                            <field name="benchmark_symbol" placeholder="E.g. VN30, VNINDEX"/>
                        </group>
                    </group>
                    <group invisible="backtest_mode == 'simple'">
                        <group string="Advanced Settings">
                            <field name="n_monte_carlo" invisible="backtest_mode != 'monte_carlo'"/>
                            <field name="n_walk_forward_windows" invisible="backtest_mode != 'walk_forward'"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_run_backtest" string="Run Backtest" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_backtest_wizard" model="ir.actions.act_window">
        <field name="name">Run Backtest</field>
        <field name="res_model">backtest.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_ai_strategy"/>
        <field name="binding_view_types">form</field>
    </record>
</odoo>
