<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="custom_reset_password_inherit" inherit_id="auth_signup.reset_password">
        <xpath expr="." position="replace">
            <t t-call="web.layout">
                <t t-set="title">Đặt lại mật khẩu</t>
                <t t-set="head">
                    <!-- Google Fonts: Inter & Playfair Display -->
                    <link rel="preconnect" href="https://fonts.googleapis.com"/>
                    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
                    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;family=Playfair+Display:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>

                    <!-- Bootstrap 5 CDN -->
                    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
                    <!-- FontAwesome CDN -->
                    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>

                    <!-- Odoo SCSS Assets -->
                    <t t-call-assets="web.assets_frontend" t-css="true" t-js="false"/>
                </t>

                <!-- Page Content -->
                <div class="auth-page">
                    <div class="reset-card auth-card-wide">
                        <div class="auth-row">
                            <!-- Left side - Illustration -->
                            <div class="auth-illustration">
                                <img src="/custom_auth/static/src/img/hdc-logo.png" alt="HDC Logo" class="hdc-logo"/>
                                <img src="/custom_auth/static/src/img/reset-password.png" alt="Reset Password Illustration" class="auth-img"/>
                            </div>

                            <!-- Right side - Form -->
                            <div class="auth-form-section">
                                <!-- Title -->
                                <div class="reset-logo">
                                    <h1 class="reset-title">Đặt lại mật khẩu</h1>
                                    <p class="reset-subtitle" t-if="not token">Nhập email của bạn để nhận hướng dẫn đặt lại mật khẩu</p>
                                    <p class="reset-subtitle" t-if="token">Nhập mật khẩu mới của bạn</p>
                                </div>

                                <!-- Success/Error Messages -->
                                <t t-if="message">
                                    <div t-attf-class="alert alert-#{message_type or 'info'}">
                                        <t t-esc="message"/>
                                    </div>
                                </t>

                                <!-- Form -->
                                <form class="reset-form" method="post" action="/web/reset_password">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                    <t t-if="token">
                                        <input type="hidden" name="token" t-att-value="token"/>
                                        <div class="form-group mb-3">
                                            <label class="form-label" for="password">Mật khẩu mới</label>
                                            <input type="password" class="form-control" id="password" name="password" required="required" autofocus="autofocus"/>
                                        </div>
                                        <div class="form-group mb-3">
                                            <label class="form-label" for="confirm_password">Xác nhận mật khẩu</label>
                                            <input type="password" class="form-control" id="confirm_password" name="confirm_password" required="required"/>
                                        </div>
                                    </t>

                                    <t t-if="not token">
                                        <div class="form-group">
                                            <label class="form-label" for="login">Địa chỉ Email</label>
                                            <input type="email" class="form-control" id="login" name="login" placeholder="email@domain.com" required="required" autofocus="autofocus"/>
                                        </div>
                                    </t>

                                    <button type="submit" class="btn-reset">
                                        <t t-if="not token">
                                            <i class="fas fa-paper-plane me-2"></i>Gửi email đặt lại
                                        </t>
                                        <t t-if="token">
                                            <i class="fas fa-check-circle me-2"></i>Đổi mật khẩu
                                        </t>
                                    </button>
                                </form>

                                <!-- Footer -->
                                <div class="reset-footer">
                                    <a href="/web/login">
                                        <i class="fas fa-arrow-left me-1"></i>Quay lại đăng nhập</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
            </t>
        </xpath>
    </template>
</odoo>