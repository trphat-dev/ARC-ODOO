<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>

        <record id="action_investment" model="ir.actions.act_window">
            <field name="name">Investments</field>
            <field name="res_model">portfolio.investment</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_portfolio_investment_search"/>
        </record>

        <record id="action_fund" model="ir.actions.act_window">
            <field name="name">Funds</field>
            <field name="res_model">portfolio.fund</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_portfolio_fund_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first fund!
                </p>
            </field>
        </record>



        <record id="action_transactions" model="ir.actions.act_window">
            <field name="name">Transactions</field>
            <field name="res_model">portfolio.transaction</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_portfolio_transaction_search"/>
        </record>

        <record id="action_account_balance" model="ir.actions.act_window">
            <field name="name">Account Balance</field>
            <field name="res_model">portfolio.account_balance</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_balance_history" model="ir.actions.act_window">
            <field name="name">Balance History</field>
            <field name="res_model">portfolio.balance_history</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_comparisons" model="ir.actions.act_window">
            <field name="name">Comparisons</field>
            <field name="res_model">portfolio.comparison</field>
            <field name="view_mode">list,form</field>
        </record>
        
    </data>
</odoo>