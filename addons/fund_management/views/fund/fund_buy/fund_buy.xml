<odoo>
  <template id="fund_buy" name="Fund Buy Page">
    <t t-call="web.layout">
      <t t-set="title">Đặt lệnh mua</t>

      <t t-call-assets="web.assets_frontend" t-js="true"/>
      <t t-set="head">
        <link rel="preconnect" href="https://fonts.googleapis.com"/>
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
        <meta name="theme-color" content="#F26522"/>
      </t>

      <div class="fm fm-page-wrapper">
            <div class="main-content mx-auto w-100" style="width: 100%; max-width: 900px; background: transparent; box-shadow: none; padding: 0;">
                
                <!-- NEW HEADER -->
                <!-- Header Container (Legacy/Dynamic) -->
                <div id="header-container" class="mb-3"></div>


                
                <!-- STEPPER -->
                <div class="fm-step-indicator">
                    <div class="step active">
                        <div class="step-num">1</div>
                        <span class="step-text">Đặt lệnh</span>
                    </div>
                    <div class="step-line bg-secondary opacity-25" style="width: 30px; height: 1px;"></div>
                    <div class="step">
                        <div class="step-num">2</div>
                        <span class="step-text">Thanh toán</span>
                    </div>
                    <div class="step-line bg-secondary opacity-25" style="width: 30px; height: 1px;"></div>
                    <div class="step">
                        <div class="step-num">3</div>
                        <span class="step-text">Hoàn tất</span>
                    </div>
                </div>

                <div class="row g-0 fm-card-modern overflow-hidden">
                    <!-- LEFT COLUMN: INPUT FORM -->
                    <div class="col-lg-8 p-0 border-end border-light">
                        <div class="p-4">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h4 class="fm-section-title mb-0 text-fm-primary fw-bold" style="letter-spacing: 0.5px; border-bottom: 2px solid #F26522; display: inline-block; padding-bottom: 5px;">Thông tin đặt lệnh</h4>
                                <!-- Navigation Tabs (Moved Here) -->
                                <div class="d-flex bg-light rounded-pill p-1 border">
                                    <a href="/fund_buy" class="btn btn-sm btn-success text-white fw-bold rounded-pill px-4 py-2" style="border-radius: 50rem !important;">
                                        Mua
                                    </a>
                                    <a href="/fund_sell" class="btn btn-sm text-decoration-none text-danger fw-medium rounded-pill px-4 py-2 bg-transparent">
                                        Bán
                                    </a>
                                </div>
                            </div>
                            
                            <!-- ORDER MODE TABS: Thỏa thuận vs Thường -->
                            <div class="order-mode-tabs mb-3" id="order-mode-tabs">
                                <button type="button" class="order-mode-tab active" data-mode="negotiated" id="tab-negotiated">
                                    <i class="fas fa-handshake"></i>
                                    <span>Đặt lệnh thỏa thuận</span>
                                </button>
                                <button type="button" class="order-mode-tab" data-mode="normal" id="tab-normal">
                                    <i class="fas fa-exchange-alt"></i>
                                    <span>Đặt lệnh thông thường</span>
                                </button>
                            </div>
                            
                            <!-- NORMAL ORDER FORM (Hidden by default, OWL component mount target) -->
                            <div id="normal-order-form-container" class="d-none">
                                <!-- NormalOrderFormComponent will be mounted here -->
                            </div>
                            
                            <!-- NEGOTIATED ORDER FORM (Default visible) -->
                            <div id="negotiated-order-form">
                            <form id="fund-buy-form">
                                <!-- Fund Selection -->
                                <div class="mb-3">
                                    <label for="fund-search" class="form-label text-secondary fw-bold fs-xs mb-2">Chọn quỹ đầu tư</label>
                                    <div class="input-group shadow-sm rounded-pill border p-1 bg-white">
                                        <span class="input-group-text bg-white border-0 ps-3 pe-2"><i class="fas fa-search text-fm-primary fs-5"></i></span>
                                        <input id="fund-search" type="text" class="form-control border-0 bg-white fs-6 py-2 shadow-none" placeholder="Tìm kiếm mã quỹ..." style="outline: none;"/>
                                    </div>
                                    <select id="fund-select" class="form-select d-none"></select>
                                    
                                    <!-- Current NAV Display (Contextual) -->
                                    <div class="mt-2 p-2 bg-fm-primary-light rounded-3 border border-fm-primary border-opacity-10 d-flex align-items-center gap-3">
                                        <div class="fm-icon-box fm-primary mb-0" style="width: 32px; height: 32px; font-size: 1rem;">
                                            <i class="fas fa-chart-line"></i>
                                        </div>
                                        <div>
                                            <span class="text-secondary fw-bold d-block" style="font-size: 0.65rem;">Giá NAV hiện tại</span>
                                            <div class="d-flex align-items-baseline gap-1">
                                                <strong id="current-nav" class="text-fm-primary fs-6">--</strong>
                                                <span class="text-xs text-secondary">VNĐ</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <input type="hidden" id="current-id"/>

                                <div class="row g-3">
                                    <!-- Amount -->
                                    <div class="col-md-6">
                                        <label for="investment-amount-input" class="form-label text-secondary fw-bold mb-1 fs-xs">Số tiền đầu tư</label>
                                        <div class="input-group position-relative">
                                            <input type="text" id="investment-amount-input" class="form-control fm-input-modern pe-5 text-end" placeholder="0"/>
                                            <span class="position-absolute end-0 top-50 translate-middle-y me-3 text-secondary fw-bold z-10 fs-xs" style="z-index: 5;">VNĐ</span>
                                        </div>
                                        <div class="form-text text-warning mt-1 fs-xs" id="min-investment-hint"></div>
                                    </div>

                                    <!-- Quantity -->
                                    <div class="col-md-6">
                                        <label for="share-quantity-input" class="form-label text-secondary fw-bold mb-1 fs-xs">Số lượng CCQ</label>
                                        <input type="text" id="share-quantity-input" class="form-control fm-input-modern text-end" placeholder="0"/>
                                        <div class="form-text text-muted mt-1 fs-xs">Tối thiểu: 20,000 CCQ</div>
                                        <input id="amount-input" type="hidden"/>
                                    </div>

                                    <!-- Term -->
                                    <div class="col-md-6">
                                        <label for="term-select" class="form-label text-secondary fw-bold mb-1 fs-xs">Kỳ hạn</label>
                                        <select id="term-select" class="form-select fm-input-modern py-1" style="background-image: none;">
                                            <option value="" disabled="disabled" selected="selected">Chọn kỳ hạn</option>
                                        </select>
                                    </div>

                                    <!-- Interest Rate (Readonly) -->
                                    <div class="col-md-6">
                                        <label class="form-label text-secondary fw-bold mb-1 fs-xs">Lãi suất</label>
                                        <div id="interest-rate" class="form-control fm-input-modern bg-light text-success fw-bold py-2">-- %</div>
                                    </div>
                                </div>
                                
                                <div class="mt-3 pt-3 border-top">
                                    <div class="row g-3">

                                         <div class="col-md-6">
                                             <label class="form-label text-secondary fw-bold fs-xs mb-1">Giá trị sau đáo hạn</label>
                                             <div id="final-value" class="form-control fm-input-modern bg-light border-0 fw-bold text-fm-primary py-2 fa-fade">--</div>
                                         </div>
                                         

                                         <div class="col-md-4">
                                            <label class="form-label text-secondary fw-bold fs-xs mb-1">Giá bán sau đáo hạn</label>
                                            <div id="maturity-price" class="form-control fm-input-modern bg-light border-0 py-2 text-xs fw-bold">--</div>
                                         </div>
                                    </div>
                                    </div>
                                    <!-- Debug Toggle -->
                                    <div class="mt-3 border-top pt-2">
                                       <div class="form-check form-switch d-flex align-items-center gap-2">
                                          <input type="checkbox" id="fund-buy-debug-toggle" class="form-check-input" style="cursor: pointer;"/>
                                          <label class="form-check-label text-sm text-muted cursor-pointer select-none" for="fund-buy-debug-toggle" style="font-size: 0.75rem;">Debug Mode (Bỏ qua ràng buộc)</label>
                                          <button type="button" id="debug-btn" class="btn btn-sm btn-fm-primary text-white ms-2 px-3 rounded-pill shadow-sm" title="Xem thuật toán tính toán">
                                              <i class="fas fa-calculator me-1"></i> Debug Tính toán
                                          </button>
                                       </div>
                                       
                                       <!-- Debug Options (Hidden by default, shown when debug toggle is ON) -->
                                       <div id="fund-buy-debug-options" class="mt-2 ps-4 d-none" style="border-left: 2px solid #ffc107;">
                                          <div class="form-check mb-1">
                                             <input type="checkbox" id="debug-skip-min-ccq" class="form-check-input debug-option" checked="checked"/>
                                             <label class="form-check-label text-xs text-muted" for="debug-skip-min-ccq">Bỏ qua min 20,000 CCQ</label>
                                          </div>
                                          <div class="form-check mb-1">
                                             <input type="checkbox" id="debug-skip-max-ccq" class="form-check-input debug-option"/>
                                             <label class="form-check-label text-xs text-muted" for="debug-skip-max-ccq">Bỏ qua max 500,000 CCQ</label>
                                          </div>
                                          <div class="form-check mb-1">
                                             <input type="checkbox" id="debug-skip-lot-size" class="form-check-input debug-option" checked="checked"/>
                                             <label class="form-check-label text-xs text-muted" for="debug-skip-lot-size">Bỏ qua lô 100 CCQ</label>
                                          </div>
                                          <div class="form-check mb-1">
                                             <input type="checkbox" id="debug-skip-profit-check" class="form-check-input debug-option" checked="checked"/>
                                             <label class="form-check-label text-xs text-muted" for="debug-skip-profit-check">Bỏ qua check lãi/lỗ</label>
                                          </div>
                                       </div>
                                       
                                       <p id="fund-buy-debug-warning" class="mt-1 text-xs text-warning d-none">
                                           <i class="fas fa-exclamation-triangle me-1"></i> <span id="debug-warning-text">Debug mode ON</span>
                                       </p>
                                    </div>

                            </form>
                            </div><!-- END negotiated-order-form -->
                        </div>
                    </div>

                    <!-- RIGHT COLUMN: SUMMARY -->
                    <div class="col-lg-4">
                        <div class="fm-summary-section">
                            <h5 class="fm-section-title mb-3">Chi tiết lệnh mua</h5>
                            
                            <div class="d-flex flex-column gap-2">
                                <div class="fm-summary-item">
                                    <span>Quỹ đầu tư</span>
                                    <strong id="summary-fund-name" class="text-end">--</strong>
                                </div>
                                <div class="fm-summary-item">
                                    <span>Ngày đặt lệnh</span>
                                    <strong id="buy-order-date">--/--/----</strong>
                                </div>
                                <div class="fm-summary-item negotiated-only">
                                    <span>Kỳ hạn</span>
                                    <strong id="summary-term">--</strong>
                                </div>
                                <div class="fm-summary-item negotiated-only">
                                    <span>Lãi suất</span>
                                    <strong id="summary-interest" class="text-success">--</strong>
                                </div>
                                
                                <div class="fm-summary-item negotiated-only">
                                    <span>Ngày đáo hạn</span>
                                    <strong id="summary-maturity-date">--/--/----</strong>
                                </div>
                                <div class="fm-summary-item negotiated-only">
                                    <span>Ngày bán lại</span>
                                    <strong id="summary-resale-date">--/--/----</strong>
                                </div>
                                <div class="fm-summary-item negotiated-only">
                                    <span>Giá trị sau đáo hạn</span>
                                    <strong id="summary-final-value">--</strong>
                                </div>
                                <div class="fm-summary-item">
                                    <span>Phí mua</span>
                                    <strong id="summary-fee">0đ</strong>
                                </div>
                                
                                <!-- Hidden Summary Fields for JS Logic -->
                                <span id="summary-units" class="d-none">0</span>
                                <span id="summary-investment-amount" class="d-none">0</span>
                                <span id="summary-amount" class="d-none">0</span>

                                <div class="p-3 bg-white rounded-3 shadow-sm border mt-2">
                                    <span class="text-secondary text-xs fw-bold d-block mb-1">Tổng thanh toán dự kiến</span>
                                    <strong id="summary-total" class="text-danger fs-5 fw-bold d-block">0</strong>
                                </div>


                                

                            </div>

                            <div class="mt-auto pt-3">
                                <button type="button" class="btn w-100 py-3 rounded-pill text-white fw-bold shadow-sm mb-2 hover-lift" 
                                        id="payment-btn" 
                                        style="background: linear-gradient(90deg, #F26522 0%, #ff8a50 100%); font-size: 1rem;">
                                    Đặt lệnh <i class="fas fa-arrow-right ms-2"></i>
                                </button>
                                <button id="back-btn" class="d-none"></button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Terms Modal (Inline) -->
            <div class="modal fade" id="termsModal" tabindex="-1" aria-hidden="true">
              <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content rounded-4 border-0 overflow-hidden">
                  <div class="modal-header bg-light border-bottom-0 p-3">
                    <h5 class="modal-title fw-bold">Điều khoản &amp; Điều kiện</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                  </div>
                  <div class="modal-body p-4 text-secondary" style="max-height: 50vh; overflow-y: auto;">
                    <p>Nội dung điều khoản sử dụng...</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Fee Modal (Inline) -->
            <div class="modal fade" id="feeModal" tabindex="-1" aria-hidden="true">
              <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content rounded-4 border-0">
                  <div class="modal-header bg-light border-bottom-0 p-3">
                    <h5 class="modal-title fw-bold">Biểu phí giao dịch</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                  </div>
                  <div class="modal-body p-4">
                    <table class="table table-borderless mb-0">
                        <thead class="bg-light rounded"><tr><th class="ps-3 border-0 rounded-start text-secondary text-xs">Giá trị</th><th class="text-end pe-3 border-0 rounded-end text-secondary text-xs">Phí (%)</th></tr></thead>
                        <tbody>
                            <tr><td class="ps-3">&lt; 100tr</td><td class="text-end pe-3 text-fm-primary fw-bold">0.5%</td></tr>
                            <tr><td class="ps-3">100tr - 1 tỷ</td><td class="text-end pe-3 text-fm-primary fw-bold">0.3%</td></tr>
                            <tr><td class="ps-3">&gt; 1 tỷ</td><td class="text-end pe-3 text-fm-primary fw-bold">0.1%</td></tr>
                        </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>

            <!-- Signature Modal (Inline/Fallback) -->
            <t t-call="fund_management.signature_modal_template"/>

      </div>

      <!-- Footer Container -->
      <div id="footer-container"></div>

      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    </t>
  </template>
</odoo>
