<odoo>
  <template id="fund_confirm" name="Fund Confirm Page">
    <t t-call="web.layout">
      <t t-set="title">Xác nhận lệnh mua</t>

      <t t-call-assets="web.assets_frontend" t-js="true"/>
      <t t-set="head">
        <link rel="preconnect" href="https://fonts.googleapis.com"/>
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
        <meta name="theme-color" content="#F26522"/>
        <!-- Anti-Caching Headers for Session Isolation -->
        <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate"/>
        <meta http-equiv="Pragma" content="no-cache"/>
        <meta http-equiv="Expires" content="0"/>
      </t>

      <div class="fm fm-page-wrapper">
             <div class="main-content mx-auto w-100" style="width: 100%; max-width: 900px; background: transparent; box-shadow: none; padding: 0;">
                
            <!-- Header Container (Legacy/Dynamic) -->
            <div id="header-container" class="mb-3"></div>

            <!-- STEPPER -->
            <div class="fm-step-indicator">
                <div class="step completed">
                    <div class="step-num"><i class="fas fa-check"></i></div>
                    <span class="step-text">Đặt lệnh</span>
                </div>
                <div class="step-line bg-success" style="width: 30px; height: 1px;"></div>
                <div class="step active">
                    <div class="step-num">2</div>
                    <span class="step-text">Thanh toán</span>
                </div>
                <div class="step-line bg-secondary opacity-25" style="width: 30px; height: 1px;"></div>
                <div class="step">
                    <div class="step-num">3</div>
                    <span class="step-text">Kết quả</span>
                </div>
            </div>

            <div class="row g-0 fm-card-modern overflow-hidden">
                <!-- LEFT COLUMN: PAYMENT METHOD -->
                <div class="col-lg-7 p-0 border-end border-light">
                    <div class="p-4">
                         <h4 class="fm-section-title mb-3">Phương thức thanh toán</h4>
                         
                         <form id="payment-method-form">
                              <!-- PayOS Card -->
                              <div id="payos-payment-info" class="bg-white rounded-3 border border-1 border-fm-primary-light shadow-sm position-relative overflow-hidden mb-3">
                                  <!-- QR Code Container -->
                                  <div id="payos-qr-code" class="text-center p-3" style="display: none;"></div>

                                  <!-- Checkout Link Container -->
                                  <div id="payos-inline-checkout" class="rounded-3 overflow-hidden">
                                     <div class="d-flex flex-column align-items-center justify-content-center p-4" style="min-height: 200px;">
                                        <div class="spinner-border text-fm-primary mb-3" role="status"></div>
                                        <span class="text-muted">Đang tạo mã thanh toán...</span>
                                     </div>
                                  </div>

                                  <!-- Error Alert -->
                                  <div id="payos-error" class="alert alert-danger mt-3 d-none py-2 px-3 text-sm">
                                    <i class="fas fa-exclamation-circle me-2"></i>
                                    <span id="payos-error-message">Lỗi thanh toán</span>
                                  </div>
                                  
                                  <!-- Fallback: Open External Payment Link -->
                                  <div class="mt-3 pt-2 border-top text-center pb-3">
                                       <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill px-4 fw-medium" id="payos-payment-btn">
                                            <i class="fas fa-external-link-alt me-2"></i> Mở trang thanh toán riêng
                                       </button>
                                  </div>
                              </div>
                         </form>
                    </div>
                </div>

                <!-- RIGHT COLUMN: SUMMARY -->
                <div class="col-lg-5">
                    <div class="fm-summary-section">
                        <h5 class="fm-section-title mb-3">Chi tiết đơn hàng</h5>
                        
                        <div class="d-flex flex-column gap-2">
                            <div class="fm-summary-item">
                                <span>Quỹ đầu tư</span>
                                <strong id="confirm-fund-name" class="text-end text-dark">--</strong>
                            </div>
                            <!-- Dynamic Details -->
                            <div class="fm-summary-item" id="row-order-type" style="display:none;">
                                <span>Loại lệnh</span>
                                <strong id="confirm-order-type" class="text-end">--</strong>
                            </div>
                            <div class="fm-summary-item" id="row-order-price" style="display:none;">
                                <span>Giá đặt</span>
                                <strong id="confirm-order-price" class="text-end">--</strong>
                            </div>
                            <div class="fm-summary-item" id="row-term" style="display:none;">
                                <span>Kỳ hạn</span>
                                <strong id="confirm-term-months" class="text-end">--</strong>
                            </div>
                            <div class="fm-summary-item" id="row-rate" style="display:none;">
                                <span>Lãi suất</span>
                                <strong id="confirm-interest-rate" class="text-end text-success">--</strong>
                            </div>
                            <div class="fm-summary-item">
                                <span>Ngày đặt lệnh</span>
                                <strong id="confirm-order-date">--</strong>
                            </div>
                            <div class="fm-summary-item">
                                <span>Số tiền đầu tư</span>
                                <strong id="confirm-amount" class="text-end">--</strong>
                            </div>
                            <div class="fm-summary-item">
                                <span>Tổng số CCQ</span>
                                <strong id="confirm-units" class="text-end">--</strong>
                            </div>
                            <div class="fm-summary-item">
                                <span>Phí mua</span>
                                <strong id="confirm-fee" class="text-end text-muted">--</strong>
                            </div>
                            
                            <!-- Total Highlighting -->
                            <div class="p-3 bg-white rounded-3 shadow-sm border mt-2 text-center">
                                <span class="text-secondary text-xs fw-bold d-block mb-1">Tổng tiền thanh toán</span>
                                <strong id="confirm-total-amount" class="text-danger fs-3 fw-bold">0</strong>
                            </div>
                        </div>

                        <div class="mt-auto pt-4">
                            <button type="submit" class="btn w-100 py-3 rounded-pill text-white fw-bold shadow-lg mb-2 hover-lift" 
                                    id="payment-confirm-btn" 
                                    style="background: linear-gradient(90deg, #10b981 0%, #059669 100%); font-size: 1rem;">
                                <i class="fas fa-check-circle me-2"></i> Xác nhận thanh toán
                            </button>
                            
                             <button type="button" class="btn w-100 py-2 rounded-pill text-muted fw-bold mb-3 hover-lift bg-transparent border-0" 
                                    onclick="window.history.back()"
                                    id="back-payment-btn">
                                <i class="fas fa-arrow-left me-2"></i> Quay lại
                            </button>
                        </div>
                    </div>
                </div>
            </div>
         </div>
      </div>

       <!-- Signature Modal -->
       <t t-call="fund_management.signature_modal_template"/>

       <!-- Footer Container -->
       <div id="footer-container"></div>

       <!-- Bootstrap JS -->
       <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    </t>
  </template>
</odoo>
