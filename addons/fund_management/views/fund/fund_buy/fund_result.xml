<odoo>
  <template id="fund_result" name="Fund Result Page">
    <t t-call="web.layout">
      <t t-set="title">Kết quả lệnh mua</t>

      <t t-call-assets="web.assets_frontend" t-js="true"/>
      <t t-set="head">
        <link rel="preconnect" href="https://fonts.googleapis.com"/>
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
        <meta name="theme-color" content="#F26522"/>
      </t>

      <div class="fm-result-page">
        <!-- Header Container -->
        <div id="header-container"></div>

        <div class="container py-4">
          <div class="row g-4">
            <!-- Left Column: Status & Details -->
            <div class="col-lg-8">
              <!-- Success Card -->
              <div class="fm-success-card mb-4">
                <div class="d-flex align-items-center">
                  <div class="fm-success-icon me-4 mb-0">
                    <i class="fas fa-check"></i>
                  </div>
                  <div>
                    <h2 class="fm-success-title mb-1">Đặt lệnh thành công!</h2>
                    <p class="fm-success-subtitle">
                      Trạng thái: <span id="result-status" class="fm-status-badge pending ms-1">Chờ xử lý</span>
                    </p>
                  </div>
                </div>
              </div>

              <!-- Order Details Card -->
              <div class="fm-details-card">
                <h6 class="fm-card-title"><i class="fas fa-receipt me-2"></i>Chi tiết lệnh</h6>
                
                <div class="fm-details-list">
                  <!-- Common Fields -->
                  <div class="fm-detail-row">
                    <span class="fm-detail-label">Quỹ đầu tư</span>
                    <span id="result-fund-name" class="fm-detail-value fw-bold">--</span>
                  </div>
                  <div class="fm-detail-row">
                    <span class="fm-detail-label">Ngày đặt lệnh</span>
                    <span id="result-order-date" class="fm-detail-value">--</span>
                  </div>
                  <div class="fm-detail-row highlight">
                    <span class="fm-detail-label">Số tiền đầu tư</span>
                    <span id="result-amount" class="fm-detail-value text-success fw-bold">--</span>
                  </div>
                  
                  <!-- Normal Order Fields -->
                  <div class="fm-detail-row normal-only">
                    <span class="fm-detail-label">Loại lệnh</span>
                    <span id="result-order-type" class="fm-detail-value">
                      <span class="fm-type-badge">--</span>
                    </span>
                  </div>
                  <div class="fm-detail-row normal-only">
                    <span class="fm-detail-label">Giá đặt</span>
                    <span id="result-order-price" class="fm-detail-value">--</span>
                  </div>
                  <div class="fm-detail-row normal-only">
                    <span class="fm-detail-label">Số lượng CCQ</span>
                    <span id="result-units" class="fm-detail-value">--</span>
                  </div>
                  
                  <!-- Negotiated Order Fields -->
                  <div class="fm-detail-row negotiated-only">
                    <span class="fm-detail-label">Kỳ hạn</span>
                    <span id="result-term-months" class="fm-detail-value">--</span>
                  </div>
                  <div class="fm-detail-row negotiated-only">
                    <span class="fm-detail-label">Lãi suất</span>
                    <span id="result-interest-rate" class="fm-detail-value text-primary fw-bold">--</span>
                  </div>
                  <div class="fm-detail-row negotiated-only">
                    <span class="fm-detail-label">Ngày đáo hạn</span>
                    <span id="result-maturity-date" class="fm-detail-value">--</span>
                  </div>
                  <div class="fm-detail-row negotiated-only">
                    <span class="fm-detail-label">Ngày bán lại</span>
                    <span id="result-sell-date" class="fm-detail-value">--</span>
                  </div>
                  
                  <div class="fm-detail-row">
                    <span class="fm-detail-label">Phí giao dịch (tạm tính)</span>
                    <span id="result-fee" class="fm-detail-value text-muted">--</span>
                  </div>
                </div>
                
                <!-- Maturity Box (Negotiated Only) -->
                <div class="fm-maturity-box negotiated-only">
                  <div class="fm-maturity-icon"><i class="fas fa-piggy-bank"></i></div>
                  <div class="fm-maturity-content">
                    <span class="fm-maturity-label">Giá trị sau đáo hạn</span>
                    <span id="result-maturity-value" class="fm-maturity-value">--</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Right Column: Actions -->
            <div class="col-lg-4">
              <!-- Contract Section (Negotiated Only) -->
              <div class="fm-contract-card negotiated-only mb-4">
                <h6 class="fm-card-title"><i class="fas fa-file-contract me-2"></i>Hợp đồng điện tử</h6>
                <div class="d-grid gap-2">
                  <button id="view-contract-btn" class="fm-contract-btn w-100">
                    <i class="fas fa-eye"></i> Xem hợp đồng
                  </button>
                  <button id="download-contract-btn" class="fm-contract-btn outline w-100">
                    <i class="fas fa-download"></i> Tải về
                  </button>
                </div>
              </div>

              <!-- Action Buttons -->
              <div class="fm-actions-card bg-white p-4 rounded-3 shadow-sm">
                <h6 class="fm-card-title mb-4">Thao tác</h6>
                <div class="d-grid gap-3">
                    <button id="confirm-redirect-btn" class="fm-action-btn primary w-100">
                    <i class="fas fa-check me-2"></i>Xác nhận
                    </button>
                    <button id="finish-btn" class="fm-action-btn secondary w-100">
                    <i class="fas fa-home me-2"></i>Về trang chủ
                    </button>
                    <button id="add-more-btn" class="fm-action-btn secondary w-100">
                    <i class="fas fa-plus me-2"></i>Đặt lệnh khác
                    </button>
                    <button id="cancel-order-btn" class="fm-action-btn danger w-100">
                    <i class="fas fa-times me-2"></i>Hủy lệnh này
                    </button>
                </div>
              </div>

              <!-- Support -->
              <div class="fm-support-text mt-4 text-center">
                <small class="text-muted">Cần hỗ trợ? Liên hệ <a href="tel:19001234" class="fw-bold text-primary text-decoration-none">1900 1234</a></small>
              </div>
            </div>
          </div>
        </div>

        <!-- Footer Container -->
        <div id="footer-container" class="mt-5"></div>
      </div>

      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    </t>
  </template>
</odoo>
