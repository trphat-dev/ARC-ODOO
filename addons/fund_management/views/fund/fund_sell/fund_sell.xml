<odoo>
    <template id="fund_sell" name="Fund Sell Page">
        <t t-call="web.layout">
            <t t-set="title">Đặt lệnh bán</t>

            <t t-call-assets="web.assets_frontend" t-js="true"/>
            <t t-set="head">
                <!-- fund_sell.js is already loaded via web.assets_frontend bundle (__manifest__.py) -->
                <link rel="preconnect" href="https://fonts.googleapis.com"/>
                <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
                <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
                <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
                <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
                <meta name="theme-color" content="#F26522"/>
            </t>

            <div class="fm fm-page-wrapper">
                <div class="main-content mx-auto w-100" style="width: 100%; max-width: 900px; background: transparent; box-shadow: none; padding: 0;">

                    <!-- NEW HEADER -->
                    <div id="header-container" class="mb-3"></div>
                    <!-- STEPPER -->
                    <div class="fm-step-indicator mb-4">
                        <div class="step active">
                            <div class="step-num">1</div>
                            <span class="step-text">Đặt lệnh</span>
                        </div>
                        <div class="step-line bg-secondary opacity-25" style="width: 30px; height: 1px;"></div>
                        <div class="step">
                            <div class="step-num">2</div>
                            <span class="step-text">Xác nhận</span>
                        </div>
                        <div class="step-line bg-secondary opacity-25" style="width: 30px; height: 1px;"></div>
                        <div class="step">
                            <div class="step-num">3</div>
                            <span class="step-text">Kết quả</span>
                        </div>
                    </div>

                    <div class="row g-0 fm-card-modern overflow-hidden">
                        <!-- LEFT COLUMN: INPUT FORM -->
                        <div class="col-lg-8 p-0 border-end border-light">
                            <div class="p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="fm-section-title mb-0 text-fm-primary fw-bold" style="font-size: 1rem;">Bán chứng chỉ quỹ</h5>

                                    <!-- Buy/Sell Switcher -->
                                    <div class="d-flex bg-light rounded-pill p-1 border" style="font-size: 0.8rem;">
                                        <a href="/fund_buy" class="btn btn-sm text-decoration-none text-secondary fw-medium rounded-pill px-3 py-1 bg-transparent">
                                        Mua
                                        </a>
                                        <a href="/fund_sell" class="btn btn-sm btn-danger text-white fw-bold rounded-pill px-3 py-1 shadow-sm" style="border-radius: 50rem !important;">
                                        Bán
                                        </a>
                                    </div>
                                </div>

                                <!-- ORDER MODE TABS (Matching Fund Buy Style) -->
                                <div class="order-mode-tabs mb-2">
                                    <button type="button" class="order-mode-tab active" data-mode="normal" id="tab-normal-sell">
                                        <i class="fas fa-exchange-alt"></i>
                                        <span>Bán thường</span>
                                    </button>
                                    <button type="button" class="order-mode-tab" data-mode="contract" id="tab-contract-sell">
                                        <i class="fas fa-file-contract"></i>
                                        <span>Bán theo hợp đồng</span>
                                    </button>
                                </div>

                                <!-- NORMAL SELL FORM -->
                                <div id="normal-sell-form-container" class="normal-order-form-container">
                                    <div class="normal-order-form">
                                        <!-- Fund Selection with Contextual Info -->
                                        <div class="form-group fund-selection-group">
                                            <label>Chọn quỹ để bán</label>
                                            <div class="fund-search-wrapper">
                                                <!-- Fixed: Replaced Search Input with Direct Select -->
                                                <select id="normal-sell-select" class="form-select"></select>
                                            </div>

                                            <!-- NAV Display Card -->
                                            <div class="nav-display-card mt-3">
                                                <div class="nav-icon">
                                                    <i class="fas fa-wallet"></i>
                                                </div>
                                                <div class="nav-info">
                                                    <span class="nav-label">Sở hữu</span>
                                                    <div class="nav-value">
                                                        <strong id="normal-sell-holdings">--</strong> CCQ
                                                    </div>
                                                    <!-- Added: Explicit Available Field -->
                                                    <div class="text-success small fw-bold mt-1">
                                                     Khả dụng: <span id="normal-sell-available">--</span>
                                                    </div>
                                                </div>
                                                <div class="market-badge-container">
                                                    <span class="nav-label">NAV hiện tại</span>
                                                    <div class="nav-value">
                                                        <strong id="normal-sell-nav">--</strong> VNĐ
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Order Type Selection (Grid) -->
                                        <div class="form-group order-type-section">
                                            <label>Loại lệnh</label>
                                            <div class="order-type-options-grid">
                                                <button type="button" class="order-type-option active" data-value="LO">
                                                    <span class="ot-code">LO</span>
                                                    <span class="ot-desc">Lệnh giới hạn</span>
                                                </button>
                                                <button type="button" class="order-type-option" data-value="MTL">
                                                    <span class="ot-code">MTL</span>
                                                    <span class="ot-desc">Thị trường</span>
                                                </button>
                                                <button type="button" class="order-type-option" data-value="ATO">
                                                    <span class="ot-code">ATO</span>
                                                    <span class="ot-desc">Mở cửa</span>
                                                </button>
                                                <button type="button" class="order-type-option" data-value="ATC">
                                                    <span class="ot-code">ATC</span>
                                                    <span class="ot-desc">Đóng cửa</span>
                                                </button>
                                            </div>
                                        </div>

                                        <!-- Price Input (for LO orders) -->
                                        <div class="form-group" id="normal-sell-price-group">
                                            <label>Giá bán</label>
                                            <div class="input-group">
                                                <input type="text" id="normal-sell-price" class="form-control text-end" placeholder="Nhập giá..."/>
                                                <span class="input-group-text">VNĐ</span>
                                            </div>
                                            <span class="form-text">Giá tham khảo: <strong id="normal-sell-ref-price">--</strong> VNĐ</span>
                                        </div>

                                        <!-- Quantity and Value Row -->
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label>Số lượng bán</label>
                                                    <div class="input-group">
                                                        <input type="number" id="normal-sell-quantity" class="form-control text-end" placeholder="0"/>
                                                        <span class="input-group-text">CCQ</span>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label>Giá trị ước tính</label>
                                                    <div class="input-group">
                                                        <input type="text" id="normal-sell-value" class="form-control bg-light text-end" placeholder="0" readonly="readonly"/>
                                                        <span class="input-group-text">VNĐ</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Removed Redundant Estimated Total Row -->
                                    </div>
                                </div>

                                <!-- CONTRACT SELL FORM (Hidden by default) -->
                                <div id="contract-sell-form-container" class="d-none">
                                    <form id="contract-sell-form">
                                        <!-- Contract Selection -->
                                        <div class="mb-3">
                                            <label class="form-label text-secondary fw-bold fs-xs mb-2">Chọn hợp đồng sở hữu</label>
                                            <div class="input-group shadow-sm rounded-pill border p-1 bg-white">
                                                <span class="input-group-text bg-white border-0 ps-3 pe-2">
                                                    <i class="fas fa-file-contract text-primary fs-5"></i>
                                                </span>
                                                <select id="contract-sell-select" class="form-select border-0 bg-white fs-6 py-2 shadow-none" style="outline: none;">
                                                    <option value="" selected="selected" disabled="disabled">-- Chọn hợp đồng --</option>
                                                </select>
                                            </div>
                                        </div>

                                        <!-- Contract Info Card -->
                                        <div id="contract-info-card" class="d-none">
                                            <div class="card border-0 bg-light mb-3">
                                                <div class="card-body">
                                                    <div class="row g-3">
                                                        <!-- Row 1: Code + Purchase Date -->
                                                        <div class="col-6">
                                                            <small class="text-secondary opacity-75 d-block fs-xs">Mã hợp đồng</small>
                                                            <strong id="contract-code" class="text-dark">--</strong>
                                                        </div>
                                                        <div class="col-6 text-end">
                                                            <small class="text-secondary opacity-75 d-block fs-xs">Ngày mua</small>
                                                            <strong id="contract-buy-date" class="text-dark">--</strong>
                                                        </div>

                                                        <!-- Row 2: Maturity Date + Resell Date -->
                                                        <div class="col-6">
                                                            <small class="text-secondary opacity-75 d-block fs-xs">Ngày đáo hạn</small>
                                                            <strong id="contract-maturity-date" class="text-dark">--</strong>
                                                        </div>
                                                        <div class="col-6 text-end">
                                                            <small class="text-secondary opacity-75 d-block fs-xs">Ngày bán lại</small>
                                                            <strong id="contract-sell-date" class="text-dark">--</strong>
                                                        </div>

                                                        <!-- Divider -->
                                                        <div class="col-12 border-top my-1 opacity-25"></div>

                                                        <!-- Row 3: Interest Rate + Investment Amount -->
                                                        <div class="col-6">
                                                            <small class="text-secondary opacity-75 d-block fs-xs">Lãi suất</small>
                                                            <strong id="contract-rate" class="text-success">--%</strong>
                                                        </div>
                                                        <div class="col-6 text-end">
                                                            <small class="text-secondary opacity-75 d-block fs-xs">Giá trị đầu tư</small>
                                                            <strong id="contract-amount" class="text-fm-primary fs-6">--</strong>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Sell Details Section -->
                                        <div class="mt-4 border-top pt-3">
                                            <h6 class="text-fm-primary fw-bold mb-3 fs-sm">Thông tin đặt bán</h6>
                                            <div class="row g-3">
                                                <!-- Owned Units -->
                                                <div class="col-md-6">
                                                    <label class="form-label text-secondary fw-bold fs-xs mb-1">Số lượng CCQ sở hữu</label>
                                                    <div class="input-group input-group-sm">
                                                        <input type="text" id="contract-owned-units" class="form-control bg-light fw-bold text-dark" readonly="readonly" value="0"/>
                                                        <span class="input-group-text bg-light text-secondary">CCQ</span>
                                                    </div>
                                                    <div class="text-success small fw-bold mt-1">
                                                     Khả dụng: <span id="contract-sell-available">--</span>
                                                    </div>
                                                </div>
                                                <!-- Sell Quantity -->
                                                <div class="col-md-6">
                                                    <label class="form-label text-secondary fw-bold fs-xs mb-1">Số lượng CCQ muốn bán</label>
                                                    <div class="input-group input-group-sm">
                                                        <input type="number" id="contract-sell-quantity" class="form-control fw-bold text-end" placeholder="0"/>
                                                        <span class="input-group-text text-secondary">CCQ</span>
                                                    </div>
                                                    <div class="form-text text-danger d-none fs-xs" id="contract-qty-error">Vượt quá SL sở hữu</div>
                                                </div>
                                                <!-- Sell Price -->
                                                <div class="col-md-12">
                                                    <label class="form-label text-secondary fw-bold fs-xs mb-1">Giá bán</label>
                                                    <div class="input-group input-group-sm">
                                                        <input type="text" id="contract-sell-price" class="form-control fw-bold text-dark text-end" value="0" placeholder="Nhập giá bán..."/>
                                                        <span class="input-group-text bg-light text-secondary">VNĐ</span>
                                                    </div>
                                                    <div class="form-text fs-xs text-muted">
                                                        <i class="fas fa-info-circle me-1"></i> Giá mặc định theo định giá đáo hạn. Bạn có thể điều chỉnh.</div>
                                                </div>
                                            </div>
                                        </div>


                                        <div class="form-check mt-3" id="contract-confirm-container">
                                            <input class="form-check-input" type="checkbox" id="contract-confirm-check"/>
                                            <label class="form-check-label fs-sm text-secondary" for="contract-confirm-check">
                                    Tôi xác nhận thông tin và đồng ý bán.
                                            </label>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>


                        <!-- RIGHT COLUMN: SUMMARY -->
                        <div class="col-lg-4 p-0">
                                <div class="fm-summary-section">
                                    <h5 class="fm-section-title mb-3">Tổng quan lệnh bán</h5>

                                    <div class="d-flex flex-column gap-3 flex-grow-1">
                                        <!-- Dynamic Summary Content -->
                                        <div id="summary-content">
                                            <div class="d-flex justify-content-between mb-2">
                                                <span class="text-secondary text-sm">Loại lệnh</span>
                                                <strong id="summary-order-type" class="badge bg-light text-dark border">Bán thường</strong>
                                            </div>
                                            <div class="d-flex justify-content-between mb-2">
                                                <span class="text-secondary text-sm">Ngày đặt lệnh</span>
                                                <strong id="summary-date">--/--/----</strong>
                                            </div>
                                            <hr class="my-2 opacity-25"/>
                                            <div class="d-flex justify-content-between mb-2">
                                                <span class="text-secondary text-sm">Số lượng</span>
                                                <strong id="summary-units" class="text-dark">0</strong>
                                            </div>
                                            <div class="d-flex justify-content-between mb-2">
                                                <span class="text-secondary text-sm">NAV hiện tại</span>
                                                <strong id="summary-nav" class="text-dark">--</strong>
                                            </div>
                                            <div class="d-flex justify-content-between mb-2">
                                                <span class="text-secondary text-sm">Thuế &amp; Phí (tạm)</span>
                                                <strong id="summary-fee" class="text-danger">0đ</strong>
                                            </div>
                                            <div class="d-flex justify-content-between mb-2 pt-2 border-top">
                                                <span class="text-fm-primary fw-bold">Tổng thanh toán</span>
                                                <strong id="summary-total" class="text-fm-primary fs-5">0đ</strong>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mt-4 pt-3 border-top">
                                        <button type="button" class="btn w-100 py-3 rounded-pill text-white fw-bold shadow-sm mb-2 hover-lift" id="confirm-sell-btn" disabled="disabled" style="background: linear-gradient(90deg, #F26522 0%, #ff8a50 100%); font-size: 1rem; opacity: 0.6; cursor: not-allowed;">
                                 Đặt lệnh <i class="fas fa-arrow-right ms-2"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Terms Modal (Inline) -->
                    <div class="modal fade" id="termsModal" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered modal-lg">
                            <div class="modal-content rounded-4 border-0 overflow-hidden">
                                <div class="modal-header bg-light border-bottom-0 p-3">
                                    <h5 class="modal-title fw-bold">Điều khoản &amp; Điều kiện</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body p-4 text-secondary" style="max-height: 50vh; overflow-y: auto;">
                                    <p>Nội dung điều khoản sử dụng...</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Signature Modal -->
                    <t t-call="fund_management.signature_modal_template"/>
                </div>

            <!-- Footer Container -->
            <div id="footer-container"></div>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        </t>

    </template>
</odoo>
