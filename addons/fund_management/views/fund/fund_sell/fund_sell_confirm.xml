<odoo>
  <template id="fund_sell_confirm" name="Fund Sell Confirm Page">
    <t t-call="web.layout">
      <t t-set="title">Xác nhận lệnh bán</t>
      <t t-call-assets="web.assets_frontend" t-js="true" />
      <t t-set="head">
        <script src="/fund_management/static/src/js/fund/fund_sell/fund_sell.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"/>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"/>
        <style>
            .confirm-card {
                background: #fff;
                border-radius: 12px;
                box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            }
            .info-row {
                display: flex;
                justify-content: space-between;
                padding: 12px 0;
                border-bottom: 1px dashed #eee;
            }
            .info-row:last-child { border-bottom: none; }
            .info-label { color: #6c757d; font-size: 0.9rem; }
            .info-value { font-weight: 600; color: #333; font-size: 0.95rem; text-align: right; }
        </style>
      </t>

      <div class="fm fm-page-wrapper">
          <div class="main-content mx-auto w-100" style="width: 100%; max-width: 900px;">
              <div id="header-container" class="mb-4"></div>

              <!-- Stepper -->
              <div class="fm-step-indicator mb-4">
                    <div class="step completed">
                        <div class="step-num"><i class="fas fa-check"></i></div>
                        <span class="step-text">Đặt lệnh</span>
                    </div>
                    <div class="step-line bg-success" style="width: 30px; height: 1px;"></div>
                    <div class="step active">
                        <div class="step-num">2</div>
                        <span class="step-text">Xác nhận</span>
                    </div>
                    <div class="step-line bg-secondary opacity-25" style="width: 30px; height: 1px;"></div>
                    <div class="step">
                        <div class="step-num">3</div>
                        <span class="step-text">Kết quả</span>
                    </div>
              </div>

              <div class="row justify-content-center">
                  <div class="col-lg-8">
                      <div class="confirm-card p-4">
                          <h4 class="text-center fw-bold text-primary mb-4">Xác nhận lệnh bán</h4>

                          <!-- Value Box -->
                          <div class="bg-light rounded-3 p-3 mb-4 text-center">
                              <span class="text-secondary small d-block mb-1">Tổng giá trị dự kiến nhận</span>
                              <h3 class="text-primary fw-bold mb-0" id="sell-confirm-value">--</h3>
                              <small class="text-muted fst-italic mt-2 d-block">(* Giá trị thực tế phụ thuộc vào NAV ngày khớp lệnh)</small>
                          </div>

                          <!-- General Info -->
                          <div class="mb-4">
                              <h6 class="text-uppercase text-muted fw-bold fs-xs mb-3">Thông tin lệnh</h6>
                              <div class="border rounded-3 p-3">
                                  <div class="info-row">
                                      <span class="info-label">Loại giao dịch</span>
                                      <span class="badg bg-danger-subtle text-danger px-3 py-1 rounded-pill fw-bold" id="sell-confirm-type">Bán</span>
                                  </div>
                                  <div class="info-row">
                                      <span class="info-label">Quỹ/Hợp đồng</span>
                                      <span class="info-value" id="sell-confirm-name">--</span>
                                  </div>
                                  <div class="info-row">
                                      <span class="info-label">Ngày đặt lệnh</span>
                                      <span class="info-value" id="sell-confirm-date">--/--/----</span>
                                  </div>
                              </div>
                          </div>

                          <!-- Details (Dynamic based on type) -->
                          <div class="mb-4">
                              <h6 class="text-uppercase text-muted fw-bold fs-xs mb-3">Chi tiết bán</h6>
                              <div class="border rounded-3 p-3">
                                  <!-- Normal Sell Fields -->
                                  <div id="confirm-normal-details">
                                      <div class="info-row">
                                          <span class="info-label">Số lượng bán</span>
                                          <span class="info-value" id="sell-confirm-quantity">--</span>
                                      </div>
                                      <div class="info-row">
                                          <span class="info-label">NAV gần nhất</span>
                                          <span class="info-value" id="sell-confirm-nav">--</span>
                                      </div>
                                  </div>

                                  <!-- Contract Fields (Hidden by default) -->
                                  <div id="confirm-contract-details" class="d-none">
                                      <div class="info-row">
                                          <span class="info-label">Mã hợp đồng</span>
                                          <span class="info-value" id="sell-confirm-contract-code">--</span>
                                      </div>
                                      <div class="info-row">
                                          <span class="info-label">Ngày đáo hạn</span>
                                          <span class="info-value" id="sell-confirm-maturity">--</span>
                                      </div>
                                  </div>

                                  <div class="info-row">
                                      <span class="info-label">Thuế &amp; Phí (tạm tính)</span>
                                      <span class="info-value text-danger" id="sell-confirm-fee">--</span>
                                  </div>
                              </div>
                          </div>

                          <!-- Actions -->
                          <div class="d-flex gap-3 mt-4">
                              <button type="button" class="btn btn-outline-secondary flex-fill py-2 rounded-pill fw-bold" onclick="window.history.back()">
                                  <i class="fas fa-arrow-left me-2"></i>Quay lại
                              </button>
                              <button type="button" class="btn btn-primary flex-fill py-2 rounded-pill fw-bold shadow-sm" id="sell-confirm-final-submit" style="background: #F26522; border-color: #F26522;">
                                  Xác nhận bán <i class="fas fa-check ms-2"></i>
                              </button>
                          </div>
                      </div>
                  </div>
              </div>
          </div>
          
          <div id="footer-container" class="mt-5"></div>
      </div>
    </t>
  </template>
</odoo>
