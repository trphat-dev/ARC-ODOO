<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Auto Fund Certificate Creation Cron Job -->
        <record id="cron_auto_create_fund_certificates" model="ir.cron">
            <field name="name">Auto Create Fund Certificates from OHLC</field>
            <field name="model_id" ref="model_auto_fund_certificate_creator"/>
            <field name="state">code</field>
            <field name="code">model.cron_auto_create_fund_certificates()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active">False</field>
        </record>

        <!-- Auto Sync Fund Certificates from Stock Data (Realtime Polling) -->
        <record id="cron_sync_fund_certificates_from_stock" model="ir.cron">
            <field name="name">Sync Fund Certificates from Stock Data</field>
            <field name="model_id" ref="model_fund_certificate"/>
            <field name="state">code</field>
            <field name="code">model.cron_sync_from_stock_data()</field>
            <field name="interval_number">2</field>
            <field name="interval_type">minutes</field>
            <field name="active">False</field>
        </record>
    </data>
</odoo>
