<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="bank_branch_form" name="Tạo mới Chi nhánh Ngân hàng">
        <t t-call="web.layout">
            <t t-set="title">Tạo mới Chi nhánh Ngân hàng</t>
            <t t-call-assets="web.assets_backend" t-js="true"/>
            <t t-set="head">
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
                <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
                <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
            </t>

            <!-- Header Container for Management -->
            <div id="headermana-container"></div>

            <div class="fund-management-container">
                <div class="dashboard-shell">
                    <div id="sidebarWidget"></div>

                    <main class="dashboard-main">
                        <div class="form-main-container">
                            <div class="form-card">
                                <div class="card-header-gradient">
                                    <h2 class="h3"><i class="fas fa-code-branch me-2"></i>Tạo mới Chi nhánh Ngân hàng</h2>
                                    <p>Thêm chi nhánh ngân hàng mới vào hệ thống.</p>
                                </div>

                                <form t-att-action="edit_mode and bank_branch and '/bank_branch/update/' + str(bank_branch.id) or '/bank_branch/create'" method="POST">
                                    <div class="form-section">
                                        <div class="section-header">
                                            <div class="section-icon"><i class="fas fa-building fa-lg text-primary"></i></div>
                                            <div>
                                                <h5 class="mb-1">Thông tin chi nhánh</h5>
                                                <small class="text-muted">Nhập thông tin chi nhánh ngân hàng.</small>
                                            </div>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label for="name" class="form-label fw-semibold">Tên chi nhánh <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control" name="name" required="1" t-att-value="bank_branch and bank_branch.name or ''"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="bank_id" class="form-label fw-semibold">Trực thuộc ngân hàng <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control" name="bank_id" required="1" t-att-value="bank_branch and bank_branch.bank_id and bank_branch.bank_id.name or ''"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="code" class="form-label fw-semibold">Mã hành chính</label>
                                                <input type="text" class="form-control" name="code" t-att-value="bank_branch and bank_branch.code or ''"/>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-check form-switch mt-4">
                                                    <input class="form-check-input" type="checkbox" role="switch" name="active" t-att-checked="not bank_branch or bank_branch.active and 'checked' or False"/>
                                                    <label class="form-check-label">Kích hoạt</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-section">
                                        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                                            <a href="/bank_branch_list" class="btn btn-form-secondary d-flex align-items-center justify-content-center">
                                                <i class="fas fa-times me-2"></i>Hủy bỏ
                                            </a>
                                            <button type="submit" class="btn btn-form-primary d-flex align-items-center justify-content-center">
                                                <i class="fas fa-save me-2"></i>Lưu chi nhánh
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </main>
                </div>
            </div>
        </t>
    </template>
</odoo>
