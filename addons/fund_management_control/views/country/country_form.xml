<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="country_form" name="Tạo mới Quốc gia">
        <t t-call="web.layout">
            <t t-set="title">Tạo mới Quốc gia</t>
            <t t-call-assets="web.assets_backend" t-js="true"/>
            <t t-set="head">
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
                <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
                <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
            </t>

            <!-- Header Container for Management -->
            <div id="headermana-container"></div>

            <div class="fund-management-container">
                <div class="dashboard-shell">
                    <div id="sidebarWidget"></div>

                    <main class="dashboard-main">
                        <div class="form-main-container">
                            <div class="form-card">
                                <div class="card-header-gradient">
                                    <h2 class="h3"><i class="fas fa-globe me-2"></i>Tạo mới Quốc gia</h2>
                                    <p>Thêm thông tin quốc gia mới vào hệ thống.</p>
                                </div>

                                <form t-att-action="edit_mode and country and '/country/update/' + str(country.id) or '/country/create'" method="POST">
                                    <div class="form-section">
                                        <div class="section-header">
                                            <div class="section-icon"><i class="fas fa-flag fa-lg text-primary"></i></div>
                                            <div>
                                                <h5 class="mb-1">Thông tin quốc gia</h5>
                                                <small class="text-muted">Nhập thông tin định danh quốc gia.</small>
                                            </div>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label for="name" class="form-label fw-semibold">Tên quốc gia <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control" name="name" required="1" t-att-value="country and country.name or ''"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="english_name" class="form-label fw-semibold">Tên Tiếng Anh <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control" name="english_name" required="1" t-att-value="country and country.english_name or ''"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="code" class="form-label fw-semibold">Mã quốc gia <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control" name="code" required="1" t-att-value="country and country.code or ''"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="phone_code" class="form-label fw-semibold">Mã vùng điện thoại <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control" name="phone_code" required="1" t-att-value="country and country.phone_code or ''"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="postal_code" class="form-label fw-semibold">Mã bưu chính</label>
                                                <input type="text" class="form-control" name="postal_code" t-att-value="country and country.postal_code or ''"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="vsd_code" class="form-label fw-semibold">Mã giao dịch VSD <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control" name="vsd_code" required="1" t-att-value="country and country.vsd_code or ''"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="sort_order" class="form-label fw-semibold">Trọng số sắp xếp <span class="text-danger">*</span></label>
                                                <input type="number" class="form-control" name="sort_order" required="1" t-att-value="country and country.sort_order or ''"/>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-check form-switch mt-4">
                                                    <input class="form-check-input" type="checkbox" role="switch" name="active" t-att-checked="not country or country.active and 'checked' or False"/>
                                                    <label class="form-check-label">Kích hoạt</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-section">
                                        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                                            <a href="/country_list" class="btn btn-form-secondary d-flex align-items-center justify-content-center">
                                                <i class="fas fa-times me-2"></i>Hủy bỏ
                                            </a>
                                            <button type="submit" class="btn btn-form-primary d-flex align-items-center justify-content-center">
                                                <i class="fas fa-save me-2"></i>Lưu quốc gia
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </main>
                </div>
            </div>
        </t>
    </template>
</odoo>
