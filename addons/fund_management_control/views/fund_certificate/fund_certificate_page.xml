<odoo>
    <template id="fund_management_control.fund_certificate_list" name="Fund Certificate">
        <t t-call="web.layout">
            <t t-set="title" name="Chứng chỉ quỹ" />
            <t t-call-assets="web.assets_backend" t-js="true"/>
            <t t-set="head">
                <!-- Bootstrap 5 CDN for immediate styling if assets compilation delays (Optional, prefer assets bundle in production) -->
                <!-- Ideally rely on web.assets_backend, but for this hybrid approach we keep CDN for robust grid system if Odoo's BS is older version -->
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous"/>
                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
                <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
                <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
            </t>

            <!-- Header Container for Management -->
            <div id="headermana-container"></div>

            <div class="fund-management-container">
                <div class="dashboard-shell">
                    <!-- Sidebar Widget Container -->
                    <div id="sidebarWidget"></div>

                    <!-- Main Content -->
                    <main class="dashboard-main">
                        <!-- Fund Certificate Widget will be mounted here -->
                        <div id="fundCertificateWidget">
                            <!-- Loading placeholder -->
                            <div class="d-flex justify-content-center align-items-center" style="height: 300px;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </div>
                        </div>
                    </main>
                </div>
            </div>
        </t>
    </template>
</odoo>
