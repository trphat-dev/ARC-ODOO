<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="fund_management_control.scheme_type_form" name="Tạo mới Loại chương trình">
        <t t-call="web.layout">
            <t t-set="title">Tạo mới Loại chương trình</t>
            <t t-call-assets="web.assets_backend" t-js="true"/>
            <t t-set="head">
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
                <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
                <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
            </t>

            <!-- Header Container for Management -->
            <div id="headermana-container"></div>

            <div class="fund-management-container">
                <div class="dashboard-shell">
                    <div id="sidebarWidget"></div>

                    <main class="dashboard-main">
                        <div class="form-main-container">
                            <div class="form-card">
                                <div class="card-header-gradient">
                                    <h2 class="h3"><i class="fas fa-plus-circle me-2"></i>Tạo mới loại chương trình</h2>
                                    <p>Thiết lập thông tin chi tiết cho scheme mới</p>
                                </div>

                                <form action="/scheme_type/create" method="POST" id="schemeTypeForm" novalidate="1">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    
                                    <div class="form-section">
                                        <div class="section-header">
                                            <div class="section-icon"><i class="fas fa-info-circle fa-lg text-primary"></i></div>
                                            <div>
                                                <h5 class="mb-1">Thông tin cơ bản</h5>
                                                <small class="text-muted">Nhập thông tin định danh cho scheme</small>
                                            </div>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-12">
                                                <label for="name" class="form-label fw-semibold">Tên Scheme <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control" id="name" name="name" placeholder="Ví dụ: Quỹ Đầu tư Cổ phiếu Việt Nam" required="1"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="name_acronym" class="form-label fw-semibold">Tên viết tắt <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control" id="name_acronym" name="name_acronym" placeholder="Ví dụ: VFMVF" required="1"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="scheme_code" class="form-label fw-semibold">Mã Scheme <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control" id="scheme_code" name="scheme_code" placeholder="Ví dụ: SCH001" required="1"/>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-section">
                                        <div class="section-header">
                                            <div class="section-icon"><i class="fas fa-cogs fa-lg text-success"></i></div>
                                            <div>
                                                <h5 class="mb-1">Cấu hình chức năng</h5>
                                                <small class="text-muted">Thiết lập các tính năng cho scheme</small>
                                            </div>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-6 col-lg-4">
                                                <div class="toggle-switch-card" onclick="toggleSwitchCard(this)">
                                                    <input type="checkbox" class="d-none" name="auto_invest" value="on"/>
                                                    <div class="custom-switch mb-3"><div class="switch-handle"></div></div>
                                                    <h6 class="fw-bold mb-2"><i class="fas fa-robot text-primary me-2"></i>Tự động mua</h6>
                                                </div>
                                            </div>
                                            <div class="col-md-6 col-lg-4">
                                                <div class="toggle-switch-card" onclick="toggleSwitchCard(this)">
                                                    <input type="checkbox" class="d-none" name="activate_scheme" value="on"/>
                                                    <div class="custom-switch mb-3"><div class="switch-handle"></div></div>
                                                    <h6 class="fw-bold mb-2"><i class="fas fa-power-off text-success me-2"></i>Kích hoạt</h6>
                                                </div>
                                            </div>
                                            <div class="col-md-6 col-lg-4">
                                                <div class="toggle-switch-card" onclick="toggleSwitchCard(this)">
                                                    <input type="checkbox" class="d-none" name="first_transaction_fee" value="on"/>
                                                    <div class="custom-switch mb-3"><div class="switch-handle"></div></div>
                                                    <h6 class="fw-bold mb-2"><i class="fas fa-receipt text-warning me-2"></i>Phí giao dịch đầu</h6>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-section">
                                        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                                            <a href="/scheme_type_list" class="btn btn-form-secondary d-flex align-items-center justify-content-center">
                                                <i class="fas fa-times me-2"></i>Hủy bỏ
                                            </a>
                                            <button type="submit" class="btn btn-form-primary d-flex align-items-center justify-content-center">
                                                <i class="fas fa-save me-2"></i>Lưu thông tin
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </main>
                </div>
            </div>

            <script>
                <![CDATA[
                function toggleSwitchCard(cardElement) {
                    const hiddenCheckbox = cardElement.querySelector('input[type="checkbox"]');
                    const customSwitch = cardElement.querySelector('.custom-switch');
                    const isActive = cardElement.classList.toggle('active');
                    customSwitch.classList.toggle('active', isActive);
                    hiddenCheckbox.checked = isActive;
                }
                ]]>
            </script>
        </t>
    </template>
</odoo>
