<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="fund_management_control.sip_settings_edit_form" name="Chỉnh sửa Cài đặt SIP">
        <t t-call="web.layout">
            <t t-set="title">Chỉnh sửa Cài đặt SIP</t>
            <t t-call-assets="web.assets_backend" t-js="true"/>
            <t t-set="head">
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
                <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
                <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
            </t>

            <!-- Header Container for Management -->
            <div id="headermana-container"></div>

            <div class="fund-management-container">
                <div class="dashboard-shell">
                    <div id="sidebarWidget"></div>

                    <main class="dashboard-main">
                        <div class="form-main-container">
                            <div class="form-card">
                                <div class="card-header-gradient">
                                    <h2 class="h3"><i class="fas fa-edit me-2"></i>Chỉnh sửa Cài đặt SIP</h2>
                                    <p>Cập nhật các quy tắc cho Kế hoạch Đầu tư Hệ thống (SIP).</p>
                                </div>

                                <form action="/sip_settings/update" method="POST" id="sipSettingsForm" novalidate="1">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="setting_id" t-att-value="setting.id"/>
                                    
                                    <div class="form-section">
                                        <div class="section-header">
                                            <div class="section-icon"><i class="fas fa-tasks fa-lg text-primary"></i></div>
                                            <div>
                                                <h5 class="mb-1">Lựa chọn chương trình</h5>
                                                <small class="text-muted">Chọn chương trình SIP để áp dụng các cài đặt này.</small>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-12">
                                                <label for="sip_scheme_id" class="form-label fw-semibold">Chương trình SIP <span class="text-danger">*</span></label>
                                                <select class="form-select" id="sip_scheme_id" name="sip_scheme_id" required="1">
                                                    <option value="" disabled="1">-- Vui lòng chọn một chương trình --</option>
                                                    <t t-foreach="schemes" t-as="s">
                                                        <option t-att-value="s.id" t-att-selected="s.id == setting.sip_scheme_id.id" t-esc="s.name"/>
                                                    </t>
                                                </select>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-section">
                                        <div class="section-header">
                                            <div class="section-icon"><i class="fas fa-ruler-combined fa-lg text-info"></i></div>
                                            <div>
                                                <h5 class="mb-1">Quy tắc SIP</h5>
                                                <small class="text-muted">Đặt ra các giới hạn và điều kiện cho việc đầu tư.</small>
                                            </div>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-4">
                                                <label for="min_monthly_amount" class="form-label fw-semibold">Số tiền tối thiểu/kỳ <span class="text-danger">*</span></label>
                                                <input type="number" class="form-control" id="min_monthly_amount" name="min_monthly_amount" placeholder="1000000" required="1" t-att-value="setting.min_monthly_amount"/>
                                            </div>
                                            <div class="col-md-4">
                                                <label for="min_maintenance_periods" class="form-label fw-semibold">Số kỳ duy trì tối thiểu <span class="text-danger">*</span></label>
                                                <input type="number" class="form-control" id="min_maintenance_periods" name="min_maintenance_periods" placeholder="6" required="1" t-att-value="setting.min_maintenance_periods"/>
                                            </div>
                                            <div class="col-md-4">
                                                <label for="max_non_consecutive_periods" class="form-label fw-semibold">Số kỳ bỏ lỡ tối đa <span class="text-danger">*</span></label>
                                                <input type="number" class="form-control" id="max_non_consecutive_periods" name="max_non_consecutive_periods" placeholder="2" required="1" t-att-value="setting.max_non_consecutive_periods"/>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-section">
                                        <div class="section-header">
                                            <div class="section-icon"><i class="fas fa-calendar-alt fa-lg text-warning"></i></div>
                                            <div>
                                                <h5 class="mb-1">Cấu hình Chu kỳ</h5>
                                                <small class="text-muted">Xác định tần suất và mã của chu kỳ đầu tư.</small>
                                            </div>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label for="cycle_code" class="form-label fw-semibold">Mã Chu kỳ giao dịch <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control" id="cycle_code" name="cycle_code" placeholder="Ví dụ: MONTHLY_25" required="1" t-att-value="setting.cycle_code"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="program_period" class="form-label fw-semibold">Kỳ của chương trình <span class="text-danger">*</span></label>
                                                <select class="form-select" id="program_period" name="program_period" required="1">
                                                    <t t-foreach="program_periods" t-as="pp">
                                                        <option t-att-value="pp[0]" t-att-selected="pp[0] == setting.program_period" t-esc="pp[1]"/>
                                                    </t>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="form-section">
                                        <div class="section-header">
                                            <div class="section-icon"><i class="fas fa-toggle-on fa-lg text-success"></i></div>
                                            <div>
                                                <h5 class="mb-1">Tùy chọn &amp; Kích hoạt</h5>
                                                <small class="text-muted">Các cài đặt bổ sung và trạng thái hoạt động.</small>
                                            </div>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <div t-attf-class="toggle-switch-card #{'active' if setting.allow_multiple_investments else ''}" onclick="toggleSwitchCard(this)">
                                                    <input type="checkbox" class="d-none" name="allow_multiple_investments" value="on" t-att-checked="setting.allow_multiple_investments"/>
                                                    <div t-attf-class="custom-switch mb-3 #{'active' if setting.allow_multiple_investments else ''}"><div class="switch-handle"></div></div>
                                                    <h6 class="fw-bold mb-2"><i class="fas fa-layer-group text-primary me-2"></i>Đầu tư nhiều lần/kỳ</h6>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div t-attf-class="toggle-switch-card #{'active' if setting.active else ''}" onclick="toggleSwitchCard(this)">
                                                    <input type="checkbox" class="d-none" name="active" value="on" t-att-checked="setting.active"/>
                                                    <div t-attf-class="custom-switch mb-3 #{'active' if setting.active else ''}"><div class="switch-handle"></div></div>
                                                    <h6 class="fw-bold mb-2"><i class="fas fa-power-off text-success me-2"></i>Kích hoạt Cài đặt</h6>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-section">
                                        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                                            <a href="/sip_settings_list" class="btn btn-form-secondary d-flex align-items-center justify-content-center">
                                                <i class="fas fa-times me-2"></i>Hủy bỏ
                                            </a>
                                            <button type="submit" class="btn btn-form-primary d-flex align-items-center justify-content-center">
                                                <i class="fas fa-save me-2"></i>Lưu thay đổi
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </main>
                </div>
            </div>

            <script>
                <![CDATA[
                function toggleSwitchCard(cardElement) {
                    const hiddenCheckbox = cardElement.querySelector('input[type="checkbox"]');
                    const customSwitch = cardElement.querySelector('.custom-switch');
                    const isActive = cardElement.classList.toggle('active');
                    customSwitch.classList.toggle('active', isActive);
                    hiddenCheckbox.checked = isActive;
                }
                ]]>
            </script>
        </t>
    </template>
</odoo>
