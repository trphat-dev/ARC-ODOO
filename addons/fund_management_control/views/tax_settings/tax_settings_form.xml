<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="fund_management_control.tax_settings_form" name="Tạo mới Cài đặt Thuế">
        <t t-call="web.layout">
            <t t-set="title">Tạo mới Cài đặt Thuế</t>
            <t t-call-assets="web.assets_backend" t-js="true"/>
            <t t-set="head">
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
                <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
                <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
            </t>

            <!-- Header Container for Management -->
            <div id="headermana-container"></div>

            <div class="fund-management-container">
                <div class="dashboard-shell">
                    <div id="sidebarWidget"></div>

                    <main class="dashboard-main">
                        <div class="form-main-container">
                            <div class="form-card">
                                <div class="card-header-gradient">
                                    <h2 class="h3"><i class="fas fa-plus-circle me-2"></i>Tạo mới Cài đặt Thuế</h2>
                                    <p>Nhập thông tin cài đặt thuế mới.</p>
                                </div>

                                <form action="/tax_settings/create" method="POST" id="taxSettingsForm" novalidate="1">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    
                                    <div class="form-section">
                                        <div class="section-header">
                                            <div class="section-icon"><i class="fas fa-info-circle fa-lg text-primary"></i></div>
                                            <div>
                                                <h5 class="mb-1">Thông tin cơ bản</h5>
                                                <small class="text-muted">Nhập mã và tên loại thuế.</small>
                                            </div>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label for="tax_code" class="form-label fw-semibold">Mã loại thuế <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control" id="tax_code" name="tax_code" required="1"/>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="tax_name" class="form-label fw-semibold">Tên loại thuế <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control" id="tax_name" name="tax_name" required="1"/>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-section">
                                        <div class="section-header">
                                            <div class="section-icon"><i class="fas fa-percentage fa-lg text-info"></i></div>
                                            <div>
                                                <h5 class="mb-1">Cấu hình tỷ lệ</h5>
                                                <small class="text-muted">Thiết lập tỷ lệ thuế và kích hoạt.</small>
                                            </div>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label for="tax_rate" class="form-label fw-semibold">Tỷ lệ thuế <span class="text-danger">*</span></label>
                                                <div class="input-group">
                                                    <input type="number" step="0.01" class="form-control" id="tax_rate" name="tax_rate" required="1"/>
                                                    <span class="input-group-text">%</span>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-semibold d-block mb-2">Trạng thái</label>
                                                <div class="toggle-switch-card active" onclick="toggleSwitchCard(this)">
                                                    <input type="checkbox" class="d-none" name="activate" value="on" checked="1"/>
                                                    <div class="custom-switch mb-2 active"><div class="switch-handle"></div></div>
                                                    <h6 class="fw-bold mb-0">Kích hoạt cài đặt thuế</h6>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-section">
                                        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                                            <a href="/tax_settings_list" class="btn btn-form-secondary d-flex align-items-center justify-content-center">
                                                <i class="fas fa-times me-2"></i>Hủy bỏ
                                            </a>
                                            <button type="submit" class="btn btn-form-primary d-flex align-items-center justify-content-center">
                                                <i class="fas fa-save me-2"></i>Lưu thông tin
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </main>
                </div>
            </div>

            <script>
                <![CDATA[
                function toggleSwitchCard(cardElement) {
                    const hiddenCheckbox = cardElement.querySelector('input[type="checkbox"]');
                    const customSwitch = cardElement.querySelector('.custom-switch');
                    const isActive = cardElement.classList.toggle('active');
                    customSwitch.classList.toggle('active', isActive);
                    hiddenCheckbox.checked = isActive;
                }
                ]]>
            </script>
        </t>
    </template>
</odoo>
