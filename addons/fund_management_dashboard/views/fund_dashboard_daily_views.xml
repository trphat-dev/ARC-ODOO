<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_fund_dashboard_daily_list" model="ir.ui.view">
        <field name="name">fund.dashboard.daily.list</field>
        <field name="model">fund.dashboard.daily</field>
        <field name="arch" type="xml">
            <list string="Dashboard Hàng Ngày" decoration-info="is_today == True">
                <field name="date" widget="date"/>
                <field name="total_accounts"/>
                <field name="total_investment" sum="Tổng"/>
                <field name="total_current_value" sum="Tổng"/>
                <field name="total_profit_loss" sum="Tổng"/>
                <field name="total_profit_loss_percentage" widget="percentage"/>
                <field name="today_transactions_count"/>
                <field name="today_total_amount" sum="Tổng"/>
                <field name="last_updated" widget="datetime"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_fund_dashboard_daily_form" model="ir.ui.view">
        <field name="name">fund.dashboard.daily.form</field>
        <field name="model">fund.dashboard.daily</field>
        <field name="arch" type="xml">
            <form string="Dashboard Hàng Ngày">
                <header>
                    <button name="action_refresh_data" string="Làm mới dữ liệu" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group string="Thông tin cơ bản">
                            <field name="name" readonly="1"/>
                            <field name="date" required="1"/>
                            <field name="company_id" readonly="1"/>
                            <field name="last_updated" readonly="1"/>
                        </group>
                        <group string="Tổng quan">
                            <field name="total_accounts"/>
                            <field name="total_investment"/>
                            <field name="total_current_value"/>
                            <field name="total_profit_loss" widget="monetary"/>
                            <field name="total_profit_loss_percentage" widget="percentage"/>
                        </group>
                    </group>
                    <group>
                        <group string="Giao dịch hôm nay">
                            <field name="today_transactions_count"/>
                            <field name="today_pending_count"/>
                            <field name="today_completed_count"/>
                            <field name="today_total_amount" widget="monetary"/>
                        </group>
                        <group string="Mua/Bán hôm nay">
                            <field name="today_buy_count"/>
                            <field name="today_buy_amount" widget="monetary"/>
                            <field name="today_sell_count"/>
                            <field name="today_sell_amount" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Thống kê tài khoản" name="account_stats">
                            <field name="account_stat_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="status"/>
                                    <field name="count" sum="Tổng"/>
                                </list>
                            </field>
                        </page>
                        <page string="Biến động quỹ" name="fund_movements">
                            <field name="fund_movement_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="fund_ticker"/>
                                    <field name="fund_name"/>
                                    <field name="buy_count" sum="Tổng"/>
                                    <field name="buy_units" sum="Tổng"/>
                                    <field name="buy_amount" sum="Tổng"/>
                                    <field name="sell_count" sum="Tổng"/>
                                    <field name="sell_units" sum="Tổng"/>
                                    <field name="sell_amount" sum="Tổng"/>
                                    <field name="net_units" sum="Tổng"/>
                                    <field name="net_amount" sum="Tổng"/>
                                </list>
                            </field>
                        </page>
                        <page string="CCQ Đầu Ngày" name="nav_opening">
                            <field name="nav_opening_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="fund_ticker"/>
                                    <field name="fund_name"/>
                                    <field name="opening_ccq" sum="Tổng"/>
                                    <field name="opening_price" sum="Tổng"/>
                                    <field name="opening_value" sum="Tổng"/>
                                </list>
                            </field>
                        </page>
                        <page string="Tất cả giao dịch" name="transactions">
                            <field name="transaction_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="investor_name"/>
                                    <field name="account_number"/>
                                    <field name="fund_ticker"/>
                                    <field name="fund_name"/>
                                    <field name="transaction_type"/>
                                    <field name="units" sum="Tổng"/>
                                    <field name="price"/>
                                    <field name="amount" sum="Tổng"/>
                                    <field name="status"/>
                                    <field name="source"/>
                                    <field name="matched_units"/>
                                    <field name="remaining_units"/>
                                    <field name="create_date" widget="datetime"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_fund_dashboard_daily_search" model="ir.ui.view">
        <field name="name">fund.dashboard.daily.search</field>
        <field name="model">fund.dashboard.daily</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm Dashboard">
                <field name="date"/>
                <field name="name"/>
                <separator/>
                <filter string="Hôm nay" name="today" domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="Tuần này" name="this_week" domain="[('date', '>=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Ngày" name="group_date" context="{'group_by': 'date'}"/>
                    <filter string="Công ty" name="group_company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action cho Dashboard Hàng Ngày -->
    <record id="action_fund_dashboard_daily" model="ir.actions.act_window">
        <field name="name">Dashboard Hàng Ngày</field>
        <field name="res_model">fund.dashboard.daily</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có dữ liệu dashboard nào
            </p>
            <p>
                Dữ liệu dashboard sẽ được tự động lưu khi truy cập trang dashboard tổng quan.
            </p>
        </field>
    </record>

    <!-- Action cho Dashboard Tổng Quan - Tự động tạo và mở form view của bản ghi hôm nay -->
    <record id="action_fund_management_dashboard" model="ir.actions.server">
        <field name="name">Dashboard Tổng Quan</field>
        <field name="model_id" ref="model_fund_dashboard_daily"/>
        <field name="binding_model_id" ref="model_fund_dashboard_daily"/>
        <field name="state">code</field>
        <field name="code">
# Tự động lấy hoặc tạo dashboard cho hôm nay và mở form view
dashboard = env['fund.dashboard.daily'].get_or_create_today()

# Mở form view của bản ghi hôm nay
action = {
    'type': 'ir.actions.act_window',
    'name': 'Dashboard Tổng Quan',
    'res_model': 'fund.dashboard.daily',
    'view_mode': 'form',
    'res_id': dashboard.id,
    'target': 'current',
    'views': [(False, 'form')],
    'context': {'form_view_initial_mode': 'readonly'},
}
        </field>
    </record>

    <!-- Server Action để làm mới dữ liệu (dùng cho batch action nếu cần) -->
    <record id="action_refresh_dashboard_data" model="ir.actions.server">
        <field name="name">Làm mới dữ liệu Dashboard</field>
        <field name="model_id" ref="model_fund_dashboard_daily"/>
        <field name="state">code</field>
        <field name="code">
# Lấy hoặc tạo dashboard cho hôm nay nếu chưa có record được chọn
if not records:
    dashboard = env['fund.dashboard.daily'].get_or_create_today()
    dashboard.action_refresh_data()
else:
    # Làm mới từng record được chọn
    for record in records:
        record.action_refresh_data()
        </field>
    </record>

</odoo>

