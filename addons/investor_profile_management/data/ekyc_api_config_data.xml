<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Default VNPT eKYC API Configuration -->
    <record id="ekyc_api_config_default" model="ekyc.api.config">
        <field name="name">Default Configuration</field>
        <field name="token_id"></field>
        <field name="token_key"></field>
        <field name="access_token"></field>
        <field name="public_key_ca"></field>
        <field name="base_url">https://api.idg.vnpt.vn</field>
        <field name="is_active" eval="True"/>
    </record>
</odoo>

