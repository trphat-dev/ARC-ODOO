<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_status" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.status</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/notebook/page[@name='sales_purchases']" position="after">
                <page string="Status Information" name="investor_status">
                    <field name="status_info_ids" context="{'default_partner_id': id}">
                        <list decoration-success="account_status == 'approved'" decoration-warning="account_status == 'pending'" decoration-danger="account_status == 'rejected'">
                            <field name="account_number"/>
                            <field name="referral_code"/>
                            <field name="account_status" widget="badge" decoration-success="account_status == 'approved'" decoration-warning="account_status == 'pending'" decoration-danger="account_status == 'rejected'" options="{'classes': {'success': 'text-success', 'warning': 'text-warning', 'danger': 'text-danger'}}"/>
                            <field name="profile_status" widget="badge" decoration-success="profile_status == 'complete'" decoration-warning="profile_status == 'incomplete'" options="{'classes': {'success': 'text-success', 'warning': 'text-warning'}}"/>
                            <field name="rm_id"/>
                            <field name="bda_id"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Status Info Search View -->
    <record id="view_status_info_search" model="ir.ui.view">
        <field name="name">status.info.search</field>
        <field name="model">status.info</field>
        <field name="arch" type="xml">
            <search string="Search Status Information">
                <field name="account_number"/>
                <field name="referral_code"/>
                <field name="rm_id"/>
                <field name="bda_id"/>
                <separator/>
                <filter string="Approved" name="approved" domain="[('account_status','=','approved')]"/>
                <filter string="Pending" name="pending" domain="[('account_status','=','pending')]"/>
                <filter string="Rejected" name="rejected" domain="[('account_status','=','rejected')]"/>
                <separator/>
                <filter string="Profile Complete" name="doc_received" domain="[('profile_status','=','complete')]"/>
                <filter string="Profile Incomplete" name="doc_pending" domain="[('profile_status','=','incomplete')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_status" context="{'group_by':'account_status'}"/>
                    <filter string="Profile Status" name="group_by_doc" context="{'group_by':'profile_status'}"/>
                    <filter string="RM" name="group_by_rm" context="{'group_by':'rm_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Status Info Action -->
    <record id="action_status_info" model="ir.actions.act_window">
        <field name="name">Status Information</field>
        <field name="res_model">status.info</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_status_info_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a new status information
            </p>
        </field>
    </record>
</odoo>
