<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sequence for Matched Orders -->
    <record id="seq_transaction_matched_orders" model="ir.sequence">
        <field name="name">Matched Orders Sequence</field>
        <field name="code">transaction.matched.orders</field>
        <field name="prefix">HDC-%(day)s%(month)s%(year)s/</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>
    
    <!-- Sequence for Maturity Notification Log -->
    <record id="seq_maturity_notification_log" model="ir.sequence">
        <field name="name">Maturity Notification Log Sequence</field>
        <field name="code">maturity.notification.log</field>
        <field name="prefix">LOG/%(year)s%(month)s%(day)s/</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
