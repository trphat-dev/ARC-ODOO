<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_maturity_notification_log_tree" model="ir.ui.view">
        <field name="name">maturity.notification.log.tree</field>
        <field name="model">maturity.notification.log</field>
        <field name="arch" type="xml">
            <list string="Lịch sử gửi thông báo">
                <field name="name"/>
                <field name="maturity_notification_id"/>
                <field name="notification_type"/>
                <field name="user_id"/>
                <field name="transaction_id"/>
                <field name="fund_id"/>
                <field name="sent_at"/>
                <field name="sent_status" widget="badge" decoration-success="sent_status == 'success'" decoration-danger="sent_status == 'failed'"/>
                <field name="title"/>
            </list>
        </field>
    </record>

    <!-- List view riêng để sử dụng trong One2many field của maturity notification -->
    <record id="view_maturity_notification_log_tree_inline" model="ir.ui.view">
        <field name="name">maturity.notification.log.tree.inline</field>
        <field name="model">maturity.notification.log</field>
        <field name="arch" type="xml">
            <list string="Lịch sử gửi thông báo">
                <field name="name"/>
                <field name="notification_type"/>
                <field name="sent_at"/>
                <field name="sent_status" widget="badge" decoration-success="sent_status == 'success'" decoration-danger="sent_status == 'failed'"/>
                <field name="title"/>
                <field name="channel_name"/>
                <field name="error_message" invisible="sent_status == 'success'"/>
            </list>
        </field>
    </record>

    <record id="view_maturity_notification_log_form" model="ir.ui.view">
        <field name="name">maturity.notification.log.form</field>
        <field name="model">maturity.notification.log</field>
        <field name="arch" type="xml">
            <form string="Lịch sử gửi thông báo">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="maturity_notification_id"/>
                            <field name="notification_type"/>
                            <field name="user_id"/>
                            <field name="partner_id"/>
                            <field name="transaction_id"/>
                            <field name="fund_id"/>
                        </group>
                        <group>
                            <field name="sent_at"/>
                            <field name="sent_status" widget="badge"/>
                            <field name="error_message" invisible="sent_status == 'success'"/>
                            <field name="channel_name"/>
                            <field name="sell_order_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="title"/>
                        <field name="message" widget="text"/>
                    </group>
                    <group string="Payload Data">
                        <field name="payload_data" widget="text" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_maturity_notification_log_search" model="ir.ui.view">
        <field name="name">maturity.notification.log.search</field>
        <field name="model">maturity.notification.log</field>
        <field name="arch" type="xml">
            <search string="Tìm lịch sử gửi thông báo">
                <field name="name"/>
                <field name="maturity_notification_id"/>
                <field name="transaction_id"/>
                <field name="user_id"/>
                <field name="fund_id"/>
                <filter string="Thành công" name="success" domain="[('sent_status', '=', 'success')]"/>
                <filter string="Thất bại" name="failed" domain="[('sent_status', '=', 'failed')]"/>
                <filter string="Thông báo đáo hạn" name="maturity_notification" domain="[('notification_type', '=', 'maturity_notification')]"/>
                <filter string="Xác nhận bán" name="maturity_confirmation" domain="[('notification_type', '=', 'maturity_confirmation')]"/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Loại thông báo" name="group_type" context="{'group_by': 'notification_type'}"/>
                    <filter string="Trạng thái" name="group_status" context="{'group_by': 'sent_status'}"/>
                    <filter string="Nhà đầu tư" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Quỹ" name="group_fund" context="{'group_by': 'fund_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_maturity_notification_log" model="ir.actions.act_window">
        <field name="name">Lịch sử gửi thông báo đáo hạn</field>
        <field name="res_model">maturity.notification.log</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
    </record>

</odoo>

