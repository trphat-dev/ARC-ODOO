<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- PayOS Configuration Form View -->
    <record id="view_payos_config_form" model="ir.ui.view">
        <field name="name">payos.config.form</field>
        <field name="model">payos.config</field>
        <field name="arch" type="xml">
            <form string="PayOS Configuration">
                <header>
                    <button name="action_test_connection" string="Test Connection" type="object" class="btn-primary" invisible="not client_id or not api_key or not checksum_key"/>
                    <field name="is_active" widget="boolean_toggle"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Inactive" bg_color="text-bg-secondary" invisible="is_active"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Production, Sandbox, ..."/></h1>
                    </div>
                    <group>
                        <group string="PayOS Credentials">
                            <field name="client_id" placeholder="5edf2d5c-a8d9-4eb3-..."/>
                            <field name="api_key" password="True" placeholder="••••••••"/>
                            <field name="checksum_key" password="True" placeholder="••••••••"/>
                            <field name="base_url" placeholder="https://api-merchant.payos.vn"/>
                        </group>
                        <group string="Merchant Bank Account">
                            <field name="merchant_bank_name" placeholder="e.g. Vietcombank"/>
                            <field name="merchant_account_number" placeholder="Real bank account number"/>
                            <field name="merchant_account_holder" placeholder="Account holder name"/>
                        </group>
                    </group>
                    <group>
                        <group string="Demo Mode (Thesis)">
                            <field name="demo_mode" widget="boolean_toggle"/>
                            <field name="demo_divisor" invisible="not demo_mode"/>
                            <div class="text-muted" invisible="not demo_mode">
                                <i class="fa fa-info-circle"/> Example: Amount 3,000,000 ÷ 1000 = 3,000 VND charged via PayOS
                            </div>
                        </group>
                    </group>
                    <group>
                        <group string="Connection Status">
                            <field name="last_connection_status" widget="badge" decoration-success="last_connection_status == 'success'" decoration-danger="last_connection_status == 'failed'" decoration-muted="last_connection_status == 'not_tested'"/>
                            <field name="last_connection_date" widget="datetime"/>
                            <field name="connection_message" invisible="not connection_message"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- PayOS Configuration List View -->
    <record id="view_payos_config_tree" model="ir.ui.view">
        <field name="name">payos.config.tree</field>
        <field name="model">payos.config</field>
        <field name="arch" type="xml">
            <list string="PayOS Configurations" decoration-success="is_active and last_connection_status == 'success'" decoration-muted="not is_active" decoration-danger="last_connection_status == 'failed'">
                <field name="name" string="Name"/>
                <field name="client_id" string="Client ID"/>
                <field name="merchant_account_number" string="Account Number"/>
                <field name="merchant_bank_name" string="Bank"/>
                <field name="is_active" widget="boolean_toggle" string="Active"/>
                <field name="demo_mode" widget="boolean_toggle" string="Demo" optional="show"/>
                <field name="last_connection_status" string="Status" widget="badge" decoration-success="last_connection_status == 'success'" decoration-danger="last_connection_status == 'failed'" decoration-muted="last_connection_status == 'not_tested'"/>
                <button name="action_test_connection" string="Test" type="object" icon="fa-plug" class="btn-link"/>
            </list>
        </field>
    </record>

    <!-- Action: open list first, then form on click -->
    <record id="action_payos_config" model="ir.actions.act_window">
        <field name="name">PayOS Configuration</field>
        <field name="res_model">payos.config</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_payos_config_tree"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <!-- Single top-level menu -->
    <menuitem id="menu_payos_root" name="PayOS" action="action_payos_config" groups="base.group_system" sequence="50"/>
</odoo>
