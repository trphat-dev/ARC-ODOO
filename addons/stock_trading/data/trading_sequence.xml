<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Trading Order -->
        <record id="seq_trading_order" model="ir.sequence">
            <field name="name">Trading Order</field>
            <field name="code">trading.order</field>
            <field name="prefix">ORD/%(year)s/%(month)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
