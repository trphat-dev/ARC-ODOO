<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Portal Trading Page Template -->
    <template id="portal_trading_page" name="Trading Portal Page">
        <t t-call="web.layout">
            <t t-set="title">Tài khoản giao dịch</t>
            
            <!-- Head: CSS Dependencies -->
            <t t-set="head">
                <!-- Bootstrap 5 CSS -->
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <!-- Bootstrap Icons -->
                <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet"/>
                <!-- Font Awesome 6 -->
                <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet"/>
            </t>
            
            <!-- Header Container (OWL Header Component) -->
            <div id="header-container"></div>
            
            <!-- Main Content Container -->
            <div id="trading_portal_page">
                <!-- OWL Component will render here -->
            </div>
            
            <!-- Footer Container (OWL Footer Component) -->
            <div id="footer-container"></div>
            
            <!-- Pass data to OWL component via window object -->
            <script type="text/javascript">
                (function() {
                    // Investor data
                    var investorData = null;
                    <t t-if="investor">
                        investorData = {
                            id: <t t-esc="investor.id"/>,
                            name: "<t t-esc="investor.partner_id.name if investor.partner_id else ''"/>",
                            account_number: "<t t-esc="investor.account_number or ''"/>"
                        };
                    </t>
                    
                    // Config data (backward compatible)
                    var configData = null;
                    <t t-if="config">
                        configData = {
                            id: <t t-esc="config.id"/>,
                            consumer_id: "<t t-esc="config.consumer_id or ''"/>",
                            account: "<t t-esc="config.account or ''"/>"
                        };
                    </t>
                    
                    // Balance data (backward compatible)
                    var balanceData = null;
                    <t t-if="balance_data">
                        balanceData = {
                            cash_balance: <t t-esc="balance_data.get('cash_balance', 0)"/>,
                            available_cash: <t t-esc="balance_data.get('available_cash', 0)"/>,
                            purchasing_power: <t t-esc="balance_data.get('purchasing_power', 0)"/>,
                            last_sync: "<t t-esc="balance_data.get('last_sync', '')"/>"
                        };
                    </t>
                    
                    // NEW: Accounts array - hỗ trợ nhiều tài khoản
                    var accountsData = [];
                    <t t-if="accounts">
                        <t t-foreach="accounts" t-as="acc">
                            accountsData.push({
                                id: <t t-esc="acc.get('id', 0)"/>,
                                name: "<t t-esc="acc.get('name', '')"/>",
                                account: "<t t-esc="acc.get('account', '')"/>",
                                balance: <t t-if="acc.get('balance')">{
                                    cash_balance: <t t-esc="acc.get('balance', {}).get('cash_balance', 0)"/>,
                                    available_cash: <t t-esc="acc.get('balance', {}).get('available_cash', 0)"/>,
                                    purchasing_power: <t t-esc="acc.get('balance', {}).get('purchasing_power', 0)"/>,
                                    last_sync: "<t t-esc="acc.get('balance', {}).get('last_sync', '')"/>"
                                }</t><t t-else="">null</t>
                            });
                        </t>
                    </t>
                    
                    // Set global data for OWL component
                    window.tradingPortalData = {
                        investor: investorData,
                        config: configData,
                        balance: balanceData,
                        accounts: accountsData  // NEW
                    };
                })();
            </script>
            
            <!-- CSRF Token -->
            <t t-set="csrf_token" t-value="request.csrf_token()"/>
            <meta name="csrf-token" t-att-content="csrf_token"/>
            
            <!-- JS Dependencies -->
            <t t-set="js">
                <!-- Bootstrap 5 JS Bundle -->
                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            </t>
            
            <!-- Load Odoo Frontend Assets (includes OWL) -->
            <t t-call-assets="web.assets_frontend" t-js="true"/>
        </t>
    </template>
</odoo>
