<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
  <!-- Portfolio Transaction List View -->
  <record id="view_portfolio_transaction_tree" model="ir.ui.view">
    <field name="name">portfolio.transaction.list</field>
    <field name="model">portfolio.transaction</field>
    <field name="arch" type="xml">
      <list string="Transaction List">
        <field name="name"/>
        <field name="user_id"/>
        <field name="fund_id"/>
        <field name="transaction_type"/>
        <field name="term_months"/>
        <field name="interest_rate"/>
        <field name="units"/>
        <field name="price" widget="monetary"/>
        <field name="amount"/>
        <field name="fee" widget="monetary"/>
        <field name="currency_id"/>
        <field name="status" widget="badge"
               decoration-info="status == 'pending'"
               decoration-success="status == 'completed'"
               decoration-danger="status == 'cancelled'"/>
        <field name="investment_type"/>
        <field name="created_at"/>
        <!-- Add matching fields with visibility conditions -->
        <field name="matched_units" optional="show" 
               invisible="[('transaction_type', 'not in', ['buy', 'sell'])]"/>
        <field name="remaining_units" optional="show"
               invisible="[('transaction_type', 'not in', ['buy', 'sell'])]"/>
        <field name="ccq_remaining_to_match" optional="show"
               invisible="[('transaction_type', 'not in', ['buy', 'sell'])]"/>
        <field name="is_matched" optional="show"
               invisible="[('transaction_type', 'not in', ['buy', 'sell'])]"/>
        <field name="is_split_order" optional="show" 
               widget="boolean_toggle"
               string="Lệnh được tách"
               invisible="[('transaction_type', 'not in', ['buy', 'sell'])]"/>
        <!-- Show matched orders information -->
        <field name="matched_order_ids" optional="show" 
               invisible="[('transaction_type', '!=', 'buy')]"
               string="Số lần khớp mua"/>
        <field name="matched_sell_order_ids" optional="show"
               invisible="[('transaction_type', '!=', 'sell')]"
               string="Số lần khớp bán"/>
        <!-- Add match orders button -->
        <button name="action_match_orders" 
                string="Khớp lệnh" 
                type="object" 
                icon="fa-refresh"
                invisible="['|', ('status', '!=', 'completed'), ('transaction_type', 'not in', ['buy', 'sell'])]"
                class="oe_highlight"/>
      </list>
    </field>
  </record>

  <!-- Portfolio Transaction Form View -->
  <record id="view_portfolio_transaction_form" model="ir.ui.view">
    <field name="name">portfolio.transaction.form</field>
    <field name="model">portfolio.transaction</field>
    <field name="arch" type="xml">
      <form string="Transaction">
        <header>
          <field name="status" widget="statusbar"/>
          <!-- Đóng phần còn lại của lệnh khớp một phần -->
          <button name="action_close_partial"
                  string="Đóng phần còn lại"
                  type="object"
                  class="oe_highlight"
                  invisible="['|', ('status','!=','pending'), '|', ('matched_units','&lt;=', 0), ('remaining_units','&lt;=', 0)]"/>
        </header>
        <sheet>
          <group>
            <group>
              <field name="name"/>
              <field name="user_id"/>
              <field name="fund_id"/>
              <field name="transaction_type"/>
              <field name="term_months"/>
              <field name="interest_rate"/>
              <field name="units"/>
              <field name="price" widget="monetary" string="Giá đơn vị"/>
              <field name="amount"/>
              <field name="fee" widget="monetary" string="Phí mua"/>
              <field name="currency_id"/>
            </group>
            <group>
              <field name="status"/>
              <field name="destination_fund_id"/>
              <field name="destination_units"/>
              <field name="investment_type"/>
              <field name="created_at"/>
            </group>
          </group>
          <group>
            <field name="description"/>
            <field name="reference"/>
            <field name="calculated_amount"/>
          </group>
          <group string="Thông tin khớp lệnh" invisible="[('transaction_type', 'not in', ['buy', 'sell'])]">
            <field name="matched_units"/>
            <field name="remaining_units"/>
            <field name="ccq_remaining_to_match"/>
            <field name="is_matched"/>
            <field name="is_split_order" widget="boolean_toggle" string="Lệnh được tách"/>
          </group>
          
          <!-- Thông tin tách lệnh -->
          <group string="Thông tin tách lệnh" invisible="[('is_split_order', '=', False), ('split_order_ids', '=', [])]">
            <field name="parent_order_id" readonly="1" invisible="[('is_split_order', '=', False)]"/>
            <field name="split_order_ids" nolabel="1" invisible="[('split_order_ids', '=', [])]">
              <list string="Các lệnh con được tách ra" decoration-info="status == 'pending'" decoration-success="status == 'completed'">
                <field name="name" string="Mã lệnh"/>
                <field name="units" string="Số lượng"/>
                <field name="matched_units" string="Đã khớp"/>
                <field name="remaining_units" string="Còn lại"/>
                <field name="status" widget="badge"/>
                <field name="create_date" string="Ngày tạo"/>
              </list>
            </field>
          </group>
          
          <!-- Thống kê khớp lệnh -->
          <group string="Thống kê khớp lệnh" invisible="[('transaction_type', 'not in', ['buy', 'sell'])]">
            <div class="row">
              <div class="col-6">
                <field name="matched_orders_count" string="Số lần khớp:" widget="badge" decoration-info="matched_orders_count > 0" decoration-success="matched_orders_count > 0"/>
              </div>
              <div class="col-6">
                <field name="matched_units" string="Tổng số lượng đã khớp:" widget="monetary"/>
              </div>
            </div>
          </group>
          
          <!-- Chi tiết lệnh mua đã khớp -->
          <group string="Lệnh mua đã khớp" invisible="[('transaction_type', '!=', 'buy')]">
            <field name="matched_order_ids" nolabel="1">
              <list string="Danh sách lệnh bán đã khớp với lệnh mua này" decoration-info="status == 'confirmed'" decoration-success="status == 'completed'">
                <field name="name" string="Mã khớp"/>
                <field name="match_date" string="Ngày khớp"/>
                <field name="matched_quantity" string="Số lượng khớp"/>
                <field name="matched_price" string="Giá khớp"/>
                <field name="total_value" string="Tổng giá trị"/>
                <field name="sell_order_id" string="Lệnh bán đã khớp" widget="many2one"/>
                <field name="status" string="Trạng thái" widget="badge"/>
              </list>
            </field>
          </group>
          
          <!-- Chi tiết lệnh bán đã khớp -->
          <group string="Lệnh bán đã khớp" invisible="[('transaction_type', '!=', 'sell')]">
            <field name="matched_sell_order_ids" nolabel="1">
              <list string="Danh sách lệnh mua đã khớp với lệnh bán này" decoration-info="status == 'confirmed'" decoration-success="status == 'completed'">
                <field name="name" string="Mã khớp"/>
                <field name="match_date" string="Ngày khớp"/>
                <field name="matched_quantity" string="Số lượng khớp"/>
                <field name="matched_price" string="Giá khớp"/>
                <field name="total_value" string="Tổng giá trị"/>
                <field name="buy_order_id" string="Lệnh mua đã khớp" widget="many2one"/>
                <field name="status" string="Trạng thái" widget="badge"/>
              </list>
            </field>
          </group>
        </sheet>
        <div class="oe_chatter">
          <field name="message_follower_ids"/>
          <field name="activity_ids"/>
          <field name="message_ids"/>
        </div>
      </form>
    </field>
  </record>

  <!-- Matched Orders List View -->
  <record id="view_matched_orders_list" model="ir.ui.view">
    <field name="name">transaction.matched.orders.list</field>
    <field name="model">transaction.matched.orders</field>
    <field name="arch" type="xml">
      <list string="Lệnh đã khớp" default_order="match_date desc">
        <field name="name" string="Mã khớp"/>
        <field name="match_date" string="Ngày khớp" widget="datetime"/>
        <field name="buy_order_id" string="Lệnh mua" widget="many2one"/>
        <field name="sell_order_id" string="Lệnh bán" widget="many2one"/>
        <field name="fund_id" string="Quỹ"/>
        <field name="matched_quantity" string="Số lượng khớp"/>
        <field name="matched_price" string="Giá khớp" widget="monetary"/>
        <field name="total_value" string="Tổng giá trị" widget="monetary"/>
        <field name="status" widget="badge"
               decoration-info="status == 'draft'"
               decoration-success="status == 'done'"
               decoration-danger="status == 'cancelled'"
               string="Trạng thái"/>
        <field name="match_type" string="Loại khớp"/>
      </list>
    </field>
  </record>

  <!-- Matched Orders Form View -->
  <record id="view_matched_orders_form" model="ir.ui.view">
    <field name="name">transaction.matched.orders.form</field>
    <field name="model">transaction.matched.orders</field>
    <field name="arch" type="xml">
      <form string="Lệnh đã khớp">
        <header>
          <field name="status" widget="statusbar" statusbar_visible="draft,done"/>
        </header>
        <sheet>
          <div class="oe_title">
            <h1>
              <field name="name" readonly="1"/>
            </h1>
          </div>
          <group>
            <group>
              <field name="match_date" string="Ngày khớp"/>
              <field name="status"/>
              <field name="match_type" string="Loại khớp"/>
              <field name="fund_id" string="Quỹ"/>
            </group>
            <group>
              <field name="matched_quantity" string="Số lượng khớp"/>
              <field name="matched_price" string="Giá khớp" widget="monetary"/>
              <field name="total_value" string="Tổng giá trị" widget="monetary"/>
            </group>
          </group>
          
          <!-- Thông tin lệnh mua -->
          <group string="Thông tin lệnh mua">
            <field name="buy_order_id" string="Lệnh mua"/>
            <field name="buy_units" string="Tổng số lượng"/>
            <field name="buy_price" string="Giá mua" widget="monetary"/>
            <field name="buy_remaining_units" string="Số lượng còn lại"/>
            <field name="buy_source" string="Nguồn"/>
          </group>
          
          <!-- Thông tin lệnh bán -->
          <group string="Thông tin lệnh bán">
            <field name="sell_order_id" string="Lệnh bán"/>
            <field name="sell_units" string="Tổng số lượng"/>
            <field name="sell_price" string="Giá bán" widget="monetary"/>
            <field name="sell_remaining_units" string="Số lượng còn lại"/>
            <field name="sell_source" string="Nguồn"/>
          </group>
        </sheet>
        <div class="oe_chatter">
          <field name="message_follower_ids"/>
          <field name="activity_ids"/>
          <field name="message_ids"/>
        </div>
      </form>
    </field>
  </record>

  <!-- Matched Orders Search View -->
  <record id="view_matched_orders_search" model="ir.ui.view">
    <field name="name">transaction.matched.orders.search</field>
    <field name="model">transaction.matched.orders</field>
    <field name="arch" type="xml">
      <search string="Tìm kiếm lệnh đã khớp">
        <field name="name" string="Mã khớp"/>
        <field name="buy_order_id" string="Lệnh mua"/>
        <field name="sell_order_id" string="Lệnh bán"/>
        <field name="fund_id" string="Quỹ"/>
        <field name="match_type" string="Loại khớp"/>
        <filter string="Draft" name="draft" domain="[('status', '=', 'draft')]"/>
        <filter string="Done" name="done" domain="[('status', '=', 'done')]"/>
        <filter string="Cancelled" name="cancelled" domain="[('status', '=', 'cancelled')]"/>
        <filter string="Lệnh nhỏ mua" name="buy_split" domain="[('buy_order_id.is_split_order', '=', True)]"/>
        <filter string="Lệnh nhỏ bán" name="sell_split" domain="[('sell_order_id.is_split_order', '=', True)]"/>
        <filter string="Có lệnh nhỏ" name="has_split" domain="['|', ('buy_order_id.is_split_order', '=', True), ('sell_order_id.is_split_order', '=', True)]"/>
        <filter string="Lệnh gốc" name="original_orders" domain="['&amp;', ('buy_order_id.is_split_order', '=', False), ('sell_order_id.is_split_order', '=', False)]"/>
        <filter string="Khớp thỏa thuận" name="negotiated" domain="[('match_type', '=', 'negotiated')]"/>
        <filter string="Khớp tự động" name="auto_match" domain="[('match_type', '!=', 'negotiated')]"/>
        <group expand="0" string="Nhóm theo">
          <filter string="Trạng thái" name="status" context="{'group_by': 'status'}"/>
          <filter string="Ngày khớp" name="match_date" context="{'group_by': 'match_date:day'}"/>
          <filter string="Quỹ" name="group_fund" context="{'group_by': 'fund_id'}"/>
          <filter string="Loại khớp" name="group_match_type" context="{'group_by': 'match_type'}"/>
          <filter string="Lệnh mua" name="group_buy_order" context="{'group_by': 'buy_order_id'}"/>
          <filter string="Lệnh bán" name="group_sell_order" context="{'group_by': 'sell_order_id'}"/>
        </group>
      </search>
    </field>
  </record>

  <!-- Portfolio Transaction Search View -->
  <record id="view_portfolio_transaction_search" model="ir.ui.view">
    <field name="name">portfolio.transaction.search</field>
    <field name="model">portfolio.transaction</field>
    <field name="arch" type="xml">
      <search string="Transaction Search">
        <field name="name"/>
        <field name="user_id"/>
        <field name="fund_id"/>
        <field name="transaction_type"/>
        <field name="price"/>
        <field name="amount"/>
        <field name="status"/>
        <field name="investment_type"/>
        <filter string="Pending" name="pending" domain="[('status', '=', 'pending')]"/>
        <filter string="Completed" name="completed" domain="[('status', '=', 'completed')]"/>
        <filter string="Cancelled" name="cancelled" domain="[('status', '=', 'cancelled')]"/>
        <filter string="Lệnh được tách" name="split_orders" domain="[('is_split_order', '=', True)]"/>
        <filter string="Lệnh gốc có con" name="has_split_orders" domain="[('split_order_ids', '!=', [])]"/>
        <group expand="0" string="Group By">
          <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
          <filter string="Fund" name="group_fund" context="{'group_by': 'fund_id'}"/>
          <filter string="Transaction Type" name="group_type" context="{'group_by': 'transaction_type'}"/>
          <filter string="Investment Type" name="group_investment" context="{'group_by': 'investment_type'}"/>
        </group>
      </search>
    </field>
  </record>

  <!-- Split Orders List View - View để hiển thị các lệnh nhỏ được tách ra -->
  <record id="view_split_orders_tree" model="ir.ui.view">
    <field name="name">split.orders.list</field>
    <field name="model">portfolio.transaction</field>
    <field name="arch" type="xml">
      <list string="Danh sách lệnh nhỏ (Lệnh được tách)" default_order="create_date desc">
        <field name="name" string="Mã lệnh"/>
        <field name="parent_order_id" string="Lệnh gốc" widget="many2one"/>
        <field name="user_id" string="Nhà đầu tư"/>
        <field name="fund_id" string="Quỹ"/>
        <field name="transaction_type" string="Loại" widget="badge"/>
        <field name="units" string="Số lượng"/>
        <field name="matched_units" string="Đã khớp"/>
        <field name="remaining_units" string="Còn lại"/>
        <field name="price" string="Giá" widget="monetary"/>
        <field name="amount" string="Thành tiền" widget="monetary"/>
        <field name="status" widget="badge"
               decoration-info="status == 'pending'"
               decoration-success="status == 'completed'"
               decoration-danger="status == 'cancelled'"
               string="Trạng thái"/>
        <field name="create_date" string="Ngày tạo" widget="datetime"/>
        <field name="is_split_order" widget="boolean_toggle" string="Lệnh được tách"/>
        <button name="action_match_orders" 
                string="Khớp lệnh" 
                type="object" 
                icon="fa-refresh"
                invisible="['|', ('status', '!=', 'pending'), ('transaction_type', 'not in', ['buy', 'sell'])]"
                class="oe_highlight"/>
      </list>
    </field>
  </record>

  <!-- Split Orders Search View -->
  <record id="view_split_orders_search" model="ir.ui.view">
    <field name="name">split.orders.search</field>
    <field name="model">portfolio.transaction</field>
    <field name="arch" type="xml">
      <search string="Tìm kiếm lệnh nhỏ">
        <field name="name"/>
        <field name="parent_order_id"/>
        <field name="user_id"/>
        <field name="fund_id"/>
        <field name="transaction_type"/>
        <filter string="Lệnh được tách" name="split_orders" domain="[('is_split_order', '=', True)]"/>
        <filter string="Pending" name="pending" domain="[('status', '=', 'pending')]"/>
        <filter string="Completed" name="completed" domain="[('status', '=', 'completed')]"/>
        <filter string="Cancelled" name="cancelled" domain="[('status', '=', 'cancelled')]"/>
        <filter string="Lệnh mua" name="buy" domain="[('transaction_type', '=', 'buy')]"/>
        <filter string="Lệnh bán" name="sell" domain="[('transaction_type', '=', 'sell')]"/>
        <group expand="0" string="Group By">
          <filter string="Fund" name="group_fund" context="{'group_by': 'fund_id'}"/>
          <filter string="Lệnh gốc" name="group_parent" context="{'group_by': 'parent_order_id'}"/>
          <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
          <filter string="Transaction Type" name="group_type" context="{'group_by': 'transaction_type'}"/>
          <filter string="Nhà đầu tư" name="group_user" context="{'group_by': 'user_id'}"/>
        </group>
      </search>
    </field>
  </record>

  </data>
</odoo>