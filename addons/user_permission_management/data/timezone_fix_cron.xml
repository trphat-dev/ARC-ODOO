<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cron job để tự động fix timezone cho tất cả users -->
    <record id="ir_cron_fix_timezone" model="ir.cron">
        <field name="name">Fix Timezone: Asia/Saigon -> Asia/Ho_Chi_Minh</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">model._update_all_users_timezone()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
        <field name="user_id" ref="base.user_root"/>
    </record>
</odoo>

